<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - Battle Arena</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <%- include("./includes/navbar.ejs") %>

    <!-- Hero Section -->
    <section class="hero bg-primary text-white py-5" style="background-color: #e7f0fa;">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-6">
            <h1 class="display-4 fw-bold" style="color: #2e5e99;">Host & Join Esports Tournaments Effortlessly</h1>
            <p class="lead" style="color: #0d2440;">A platform where organizers create thrilling esports leagues and players compete in high-stakes gaming battles. Join the ultimate esports community today!</p>
            <a href="#features" class="btn btn-lg me-3" style="background-color: #7ba4d0; color: white; border: none;" id="cta-btn">Explore Features</a>
            <a href="/register" class="btn btn-outline-dark btn-lg">Get Started</a>
          </div>
          <div class="col-lg-6 text-center">
            <img src="https://images.unsplash.com/photo-1542751371-adc38448a05e?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Esports players competing in a tournament" class="img-fluid rounded shadow" style="max-height: 400px;">
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-5 bg-light" style="background-color: #e7f0fa;">
      <div class="container">
        <h2 class="text-center mb-5 fw-bold" style="color: #2e5e99;">Why Choose Our Esports Platform?</h2>
        <div class="row g-4">
          <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm" style="background-color: white;">
              <div class="card-body text-center">
                <i class="bi bi-trophy-fill fs-1 mb-3" style="color: #7ba4d0;"></i>
                <h5 class="card-title" style="color: #2e5e99;">For Organizers</h5>
                <p class="card-text" style="color: #0d2440;">Easily create and manage esports tournaments with customizable game modes, live streaming integration, and automated matchmaking.</p>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm" style="background-color: white;">
              <div class="card-body text-center">
                <i class="bi bi-people-fill fs-1 mb-3" style="color: #7ba4d0;"></i>
                <h5 class="card-title" style="color: #2e5e99;">For Players</h5>
                <p class="card-text" style="color: #0d2440;">Join competitive esports leagues, track your rankings, and connect with a global network of gamers.</p>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm" style="background-color: white;">
              <div class="card-body text-center">
                <i class="bi bi-shield-check fs-1 mb-3" style="color: #7ba4d0;"></i>
                <h5 class="card-title" style="color: #2e5e99;">Secure & Fair Play</h5>
                <p class="card-text" style="color: #0d2440;">Equipped with anti-cheat systems, secure prize pools, and transparent leaderboards.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works Section -->
    <section class="py-5" style="background-color: #7ba4d0;">
      <div class="container">
        <h2 class="text-center mb-5 fw-bold text-white">How Esports Tournaments Work</h2>
        <div class="row g-4 text-center">
          <div class="col-md-4">
            <div class="step-circle mx-auto mb-3" style="width: 80px; height: 80px; background-color: #2e5e99; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
              <span class="text-white fw-bold fs-4">1</span>
            </div>
            <h5 class="text-white">Sign Up</h5>
            <p class="text-white-50">Create an account as an organizer or player.</p>
          </div>
          <div class="col-md-4">
            <div class="step-circle mx-auto mb-3" style="width: 80px; height: 80px; background-color: #2e5e99; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
              <span class="text-white fw-bold fs-4">2</span>
            </div>
            <h5 class="text-white">Host or Join</h5>
            <p class="text-white-50">Organizers launch tournaments; players register.</p>
          </div>
          <div class="col-md-4">
            <div class="step-circle mx-auto mb-3" style="width: 80px; height: 80px; background-color: #2e5e99; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
              <span class="text-white fw-bold fs-4">3</span>
            </div>
            <h5 class="text-white">Compete & Win</h5>
            <p class="text-white-50">Engage in matches and win prizes.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action Footer Section -->
    <section class="py-5 text-center" style="background-color: #2e5e99;">
      <div class="container">
        <h2 class="text-white mb-3">Ready to Start Your Esports Journey?</h2>
        <p class="text-white-50 mb-4">Sign up now and join thousands of organizers and players.</p>
        <a href="/register" class="btn btn-lg" style="background-color: #7ba4d0; color: white; border: none;">Sign Up Today</a>
      </div>
    </section>

    <%- include("./includes/footer.ejs") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/script.js"></script>
</body>
</html>