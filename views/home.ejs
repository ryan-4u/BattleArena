<% layout("/layouts/boilerplate.ejs") %>
<section class="hero text-center text-light d-flex align-items-center">
  <div class="container">
    <h1 class="display-4 fw-bold">Compete. Win. Dominate.</h1>
    <p class="lead">Join player-hosted tournaments and compete for real prize pools.</p>
    <a href="/tournaments" class="btn btn-lg btn-primary px-4 me-2">Browse Tournaments</a>
    <a href="/register" class="btn btn-lg btn-outline-light px-4">Become a Host</a>
  </div>
</section>

<section class="py-5">
  <div class="container text-center">
    <h2 class="mb-4">How Battle Arena Works</h2>
    <div class="row g-4">
      <div class="col-md-4">
        <h5>1. Join as Player</h5>
        <p>Sign up and explore tournaments created by organizers.</p>
      </div>
      <div class="col-md-4">
        <h5>2. Host a Tournament</h5>
        <p>Create your own competition with rules, prize pool, and schedule.</p>
      </div>
      <div class="col-md-4">
        <h5>3. Compete & Win</h5>
        <p>Play, win, and follow instructions from the tournament organizer.</p>
      </div>
    </div>
  </div>
</section>
