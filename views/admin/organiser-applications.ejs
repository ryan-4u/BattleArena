<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Organiser Applications | Admin</title>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>

    <div class="mb-4">
      <p class="cyber-tag-line mb-1">// ADMIN PANEL</p>
      <h2 class="fw-bold mb-0">Organiser Applications</h2>
    </div>

    <div class="d-flex gap-2 mb-4 flex-wrap">
      <a href="/admin" class="btn btn-outline-warning btn-sm">Dashboard</a>
      <a href="/admin/users" class="btn btn-outline-warning btn-sm">Users</a>
      <a href="/admin/tournaments" class="btn btn-outline-warning btn-sm">Tournaments</a>
      <a href="/admin/organiser-applications" class="btn btn-warning btn-sm">Applications</a>
    </div>

    <!-- Filter -->
    <form action="/admin/organiser-applications" method="GET" class="d-flex gap-2 mb-4">
      <select name="status" class="form-select form-select-sm" style="width:auto;">
        <option value="">All Status</option>
        <option value="pending"  <%= query.status === 'pending'  ? 'selected' : '' %>>Pending</option>
        <option value="approved" <%= query.status === 'approved' ? 'selected' : '' %>>Approved</option>
        <option value="rejected" <%= query.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
      </select>
      <button type="submit" class="btn btn-outline-warning btn-sm">Filter</button>
      <a href="/admin/organiser-applications" class="btn btn-outline-secondary btn-sm">Clear</a>
    </form>

    <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#475569; letter-spacing:0.15em; margin-bottom:16px;">
      <%= applications.length %> APPLICATION<%= applications.length !== 1 ? 'S' : '' %>
    </p>

    <% if (applications.length === 0) { %>
      <p class="text-muted">No applications found.</p>
    <% } else { %>
      <div class="d-flex flex-column gap-3">
        <% applications.forEach(app => { %>
          <div class="card ba-card">
            <div class="card-body p-4">
              <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                  <a href="/profile/<%= app.applicant._id %>"
                    style="font-family:'Orbitron',monospace; font-size:0.9rem; font-weight:700; color:var(--cyber-blue); text-decoration:none;">
                    <%= app.applicant.username %>
                  </a>
                  <div style="font-size:0.72rem; color:#475569; font-family:'Share Tech Mono',monospace; margin-top:3px;">
                    Applied <%= new Date(app.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
                    · Account created <%= new Date(app.applicant.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
                  </div>
                </div>
                <span class="badge <%= app.status === 'pending' ? 'bg-warning text-dark' : app.status === 'approved' ? 'bg-success' : 'bg-danger' %>">
                  <%= app.status.toUpperCase() %>
                </span>
              </div>

              <div class="row g-3 mb-3" style="font-size:0.82rem;">
                <div class="col-md-3">
                  <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.15em;">FULL NAME</span>
                  <div style="color:#94a3b8; margin-top:3px;"><%= app.fullName %></div>
                </div>
                <div class="col-md-3">
                  <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.15em;">TYPE</span>
                  <div style="color:#94a3b8; margin-top:3px;"><%= app.tournamentType %></div>
                </div>
                <div class="col-md-3">
                  <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.15em;">ACTIVITY</span>
                  <div style="color:#94a3b8; margin-top:3px;"><%= app.activity %></div>
                </div>
                <div class="col-md-3">
                  <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.15em;">EXPECTED SIZE</span>
                  <div style="color:#94a3b8; margin-top:3px;"><%= app.expectedParticipants %></div>
                </div>
                <div class="col-md-6">
                  <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.15em;">EXPERIENCE</span>
                  <div style="color:#94a3b8; margin-top:3px;">
                    <%= app.hasExperience ? 'Yes' : 'No' %>
                    <% if (app.experienceDetails) { %>
                      — <%= app.experienceDetails %>
                    <% } %>
                  </div>
                </div>
                <div class="col-md-6">
                  <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.15em;">SOCIAL LINK</span>
                  <div style="color:#94a3b8; margin-top:3px;">
                    <% if (app.socialLink) { %>
                      <a href="<%= app.socialLink %>" target="_blank" style="color:var(--cyber-blue);">
                        <%= app.socialLink %>
                      </a>
                    <% } else { %>
                      Not provided
                    <% } %>
                  </div>
                </div>
                <div class="col-12">
                  <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.15em;">MOTIVATION</span>
                  <div style="color:#94a3b8; margin-top:3px; font-size:0.83rem; line-height:1.6;">
                    <%= app.motivation %>
                  </div>
                </div>
              </div>

              <% if (app.status === 'pending') { %>
                <div class="d-flex gap-2">
                  <form action="/admin/organiser-applications/<%= app._id %>/approve?_method=PATCH" method="POST">
                    <button class="btn btn-success btn-sm fw-bold">
                      <i class="bi bi-check-lg"></i> Approve
                    </button>
                  </form>
                  <button class="btn btn-outline-danger btn-sm"
                    onclick="openRejectModal('<%= app._id %>', '<%= app.applicant.username %>')">
                    <i class="bi bi-x-lg"></i> Reject
                  </button>
                </div>
              <% } else if (app.status === 'rejected' && app.rejectionReason) { %>
                <div style="font-size:0.78rem; color:#ef4444; margin-top:4px;">
                  Rejection reason: <%= app.rejectionReason %>
                </div>
              <% } %>

            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Reject Modal -->
  <div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content" style="background:#0a0f1e; border:1px solid rgba(239,68,68,0.3); border-radius:0;">
        <div class="modal-header" style="border-bottom:1px solid rgba(239,68,68,0.15);">
          <h6 class="modal-title fw-bold" style="font-family:'Orbitron',monospace; font-size:0.85rem; color:#ef4444;">
            REJECT APPLICATION
          </h6>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <form id="rejectForm" method="POST">
          <input type="hidden" name="_method" value="PATCH"/>
          <div class="modal-body">
            <p style="font-size:0.83rem; color:#94a3b8; margin-bottom:14px;">
              Rejecting application from <strong id="rejectUsername" style="color:#ef4444;"></strong>
            </p>
            <label class="form-label fw-semibold">Reason for rejection</label>
            <textarea name="reason" class="form-control" rows="3"
              placeholder="Tell the applicant why they were rejected..."></textarea>
          </div>
          <div class="modal-footer" style="border-top:1px solid rgba(239,68,68,0.15);">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-danger btn-sm">Confirm Reject</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%- include('../partials/scripts') %>
  <script>
    function openRejectModal(appId, username) {
      document.getElementById("rejectUsername").textContent = username;
      document.getElementById("rejectForm").action = `/admin/organiser-applications/${appId}/reject?_method=PATCH`;
      new bootstrap.Modal(document.getElementById("rejectModal")).show();
    }
  </script>
</body>
</html>