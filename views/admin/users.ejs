<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Manage Users | BattleArena Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>

    <div class="mb-4">
      <p class="cyber-tag-line mb-1">// ADMIN PANEL</p>
      <h2 class="fw-bold mb-0">User Management</h2>
    </div>

    <div class="d-flex gap-2 mb-4 flex-wrap">
      <a href="/admin" class="btn btn-outline-warning btn-sm">Dashboard</a>
      <a href="/admin/users" class="btn btn-warning btn-sm">Users</a>
      <a href="/admin/tournaments" class="btn btn-outline-warning btn-sm">Tournaments</a>
    </div>

    <!-- Filter -->
    <form action="/admin/users" method="GET" class="row g-2 mb-4" novalidate>
      <div class="col-md-4">
        <input type="text" name="search" class="form-control"
          placeholder="Search username..." value="<%= query.search || '' %>"/>
      </div>
      <div class="col-md-3">
        <select name="role" class="form-select">
          <option value="">All Roles</option>
          <option value="player"    <%= query.role === 'player'    ? 'selected' : '' %>>Players</option>
          <option value="organiser" <%= query.role === 'organiser' ? 'selected' : '' %>>Organisers</option>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-outline-warning w-100">
          <i class="bi bi-search"></i> Filter
        </button>
      </div>
      <div class="col-md-2">
        <a href="/admin/users" class="btn btn-outline-secondary w-100">Clear</a>
      </div>
    </form>

    <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#475569; letter-spacing:0.15em; margin-bottom:16px;">
      <%= users.length %> USER<%= users.length !== 1 ? 'S' : '' %> FOUND
    </p>

    <!-- Users Table -->
    <div class="card ba-card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table mb-0" style="color:var(--cyber-text);">
            <thead style="border-bottom:1px solid rgba(56,189,248,0.15);">
              <tr style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:var(--cyber-blue); letter-spacing:0.15em;">
                <th class="px-3 py-3">USERNAME</th>
                <th class="py-3">EMAIL</th>
                <th class="py-3">ROLE</th>
                <th class="py-3">STATUS</th>
                <th class="py-3">JOINED</th>
                <th class="py-3">ACTIONS</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(user => { %>
                <tr style="border-bottom:1px solid rgba(56,189,248,0.06); font-size:0.83rem;">
                  <td class="px-3 py-3">
                    <a href="/profile/<%= user._id %>" style="color:var(--cyber-blue); font-weight:600;">
                      <%= user.username %>
                    </a>
                    <% if (user.gameUsername) { %>
                      <div style="font-size:0.68rem; color:#475569; font-family:'Share Tech Mono',monospace;">
                        <%= user.gameUsername %>
                      </div>
                    <% } %>
                  </td>
                  <td class="py-3" style="color:#64748b; font-size:0.78rem;"><%= user.email %></td>
                  <td class="py-3">
                    <span class="badge <%= user.role === 'organiser' ? 'bg-warning' : 'bg-secondary' %>">
                      <%= user.role.toUpperCase() %>
                    </span>
                  </td>
                  <td class="py-3">
                    <% if (user.banned) { %>
                      <span class="badge bg-danger">BANNED</span>
                    <% } else { %>
                      <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#22c55e; letter-spacing:0.1em;">
                        ● ACTIVE
                      </span>
                    <% } %>
                  </td>
                  <td class="py-3" style="font-size:0.72rem; color:#475569; font-family:'Share Tech Mono',monospace;">
                    <%= new Date(user.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
                  </td>
                  <td class="py-3">
                    <div class="d-flex gap-1 flex-wrap">

                      <!-- Change Role -->
                      <form action="/admin/users/<%= user._id %>/role?_method=PATCH" method="POST" class="d-inline">
                        <select name="role" class="form-select form-select-sm d-inline-block"
                          style="width:auto; font-size:0.65rem; padding:2px 6px;"
                          onchange="this.form.submit()">
                          <option value="player"    <%= user.role === 'player'    ? 'selected' : '' %>>Player</option>
                          <option value="organiser" <%= user.role === 'organiser' ? 'selected' : '' %>>Organiser</option>
                        </select>
                      </form>

                      <!-- Ban / Unban -->
                      <% if (user.banned) { %>
                        <form action="/admin/users/<%= user._id %>/unban?_method=PATCH" method="POST">
                          <button class="btn btn-success btn-sm" title="Unban">
                            <i class="bi bi-unlock"></i>
                          </button>
                        </form>
                      <% } else { %>
                        <button class="btn btn-outline-danger btn-sm"
                          onclick="openBanModal('<%= user._id %>', '<%= user.username %>')"
                          title="Ban user">
                          <i class="bi bi-slash-circle"></i>
                        </button>
                      <% } %>

                      <!-- Delete -->
                      <form action="/admin/users/<%= user._id %>?_method=DELETE" method="POST"
                        onsubmit="return confirm('Permanently delete <%= user.username %>?')">
                        <button class="btn btn-outline-danger btn-sm" title="Delete">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>

                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Ban Modal -->
  <div class="modal fade" id="banModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content" style="background:#0a0f1e; border:1px solid rgba(56,189,248,0.2); border-radius:0;">
        <div class="modal-header" style="border-bottom:1px solid rgba(56,189,248,0.1);">
          <h6 class="modal-title fw-bold" style="font-family:'Orbitron',monospace; font-size:0.85rem; color:var(--cyber-blue);">
            BAN USER
          </h6>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <form id="banForm" method="POST">
          <input type="hidden" name="_method" value="PATCH"/>
          <div class="modal-body">
            <p style="font-size:0.83rem; color:#94a3b8; margin-bottom:14px;">
              Banning: <strong id="banUsername" style="color:var(--cyber-blue);"></strong>
            </p>
            <label class="form-label fw-semibold">Ban Reason</label>
            <textarea name="reason" class="form-control" rows="3"
              placeholder="e.g. Cheating, fake tournament, harassment..."></textarea>
          </div>
          <div class="modal-footer" style="border-top:1px solid rgba(56,189,248,0.1);">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-danger btn-sm">Confirm Ban</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function openBanModal(userId, username) {
      document.getElementById("banUsername").textContent = username;
      document.getElementById("banForm").action = `/admin/users/${userId}/ban?_method=PATCH`;
      new bootstrap.Modal(document.getElementById("banModal")).show();
    }
  </script>
</body>
</html>