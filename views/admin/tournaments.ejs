<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Admin | BattleArena</title>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>

    <div class="mb-4">
      <p class="cyber-tag-line mb-1">// ADMIN PANEL</p>
      <h2 class="fw-bold mb-0">Tournament Management</h2>
    </div>

    <div class="d-flex gap-2 mb-4 flex-wrap">
      <a href="/admin" class="btn btn-outline-warning btn-sm">Dashboard</a>
      <a href="/admin/users" class="btn btn-outline-warning btn-sm">Users</a>
      <a href="/admin/tournaments" class="btn btn-warning btn-sm">Tournaments</a>
      <a href="/admin/organiser-applications" class="btn btn-outline-warning btn-sm">Applications</a>
    </div>

    <!-- Filter -->
    <form action="/admin/tournaments" method="GET" class="row g-2 mb-4" novalidate>
      <div class="col-md-4">
        <input type="text" name="search" class="form-control"
          placeholder="Search title..." value="<%= query.search || '' %>"/>
      </div>
      <div class="col-md-3">
        <select name="status" class="form-select">
          <option value="">All Status</option>
          <option value="upcoming"  <%= query.status === 'upcoming'  ? 'selected' : '' %>>Upcoming</option>
          <option value="ongoing"   <%= query.status === 'ongoing'   ? 'selected' : '' %>>Ongoing</option>
          <option value="completed" <%= query.status === 'completed' ? 'selected' : '' %>>Completed</option>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-outline-warning w-100">
          <i class="bi bi-search"></i> Filter
        </button>
      </div>
      <div class="col-md-2">
        <a href="/admin/tournaments" class="btn btn-outline-secondary w-100">Clear</a>
      </div>
    </form>

    <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#475569; letter-spacing:0.15em; margin-bottom:16px;">
      <%= tournaments.length %> TOURNAMENT<%= tournaments.length !== 1 ? 'S' : '' %> FOUND
    </p>

    <div class="card ba-card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table mb-0" style="color:var(--cyber-text);">
            <thead style="border-bottom:1px solid rgba(56,189,248,0.15);">
              <tr style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:var(--cyber-blue); letter-spacing:0.15em;">
                <th class="px-3 py-3">TITLE</th>
                <th class="py-3">GAME</th>
                <th class="py-3">ORGANISER</th>
                <th class="py-3">STATUS</th>
                <th class="py-3">REPORTS</th>
                <th class="py-3">VISIBILITY</th>
                <th class="py-3">ACTIONS</th>
              </tr>
            </thead>
            <tbody>
              <% tournaments.forEach(t => { %>
                <tr style="border-bottom:1px solid rgba(56,189,248,0.06); font-size:0.83rem;">
                  <td class="px-3 py-3">
                    <a href="/tournaments/<%= t._id %>" style="color:var(--cyber-blue); font-weight:600;">
                      <%= t.title %>
                    </a>
                    <div style="font-size:0.68rem; color:#475569; font-family:'Share Tech Mono',monospace;">
                      <%= t.mode %> / <%= t.maxPlayers %> max
                    </div>
                  </td>
                  <td class="py-3" style="font-family:'Share Tech Mono',monospace; font-size:0.7rem; color:#64748b;">
                    <%= t.game %>
                  </td>
                  <td class="py-3">
                    <a href="/profile/<%= t.organiser._id %>" style="font-size:0.8rem; color:#94a3b8;">
                      <%= t.organiser.username %>
                    </a>
                  </td>
                  <td class="py-3">
                    <span class="badge
                      <%= t.status === 'upcoming'  ? 'bg-success'  :
                          t.status === 'ongoing'   ? 'bg-warning'  : 'bg-secondary' %>">
                      <%= t.status.toUpperCase() %>
                    </span>
                  </td>

                  <!-- REPORTS COLUMN -->
                  <td class="py-3">
                    <% if (t.status === 'completed') { %>
                      <div class="d-flex flex-column gap-1">
                        <% if (t.resultReports && t.resultReports.length > 0) { %>
                          <button class="btn btn-sm btn-outline-danger"
                            style="font-size:0.65rem; padding:2px 8px;"
                            onclick='openTournamentReportsModal(
                              "<%= t.title.replace(/"/g, "") %>",
                              <%= t.resultReports.length %>,
                              <%= t.resultSupports ? t.resultSupports.length : 0 %>,
                              <%= JSON.stringify(t.resultReports.map(r => ({ reason: r.reason }))) %>
                            )'>
                            <i class="bi bi-flag-fill"></i> <%= t.resultReports.length %> report<%= t.resultReports.length !== 1 ? 's' : '' %>
                          </button>
                        <% } %>
                        <% if (t.resultSupports && t.resultSupports.length > 0) { %>
                          <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#22c55e; letter-spacing:0.1em;">
                            ✓ <%= t.resultSupports.length %> support<%= t.resultSupports.length !== 1 ? 's' : '' %>
                          </span>
                        <% } %>
                        <% if ((!t.resultReports || t.resultReports.length === 0) && (!t.resultSupports || t.resultSupports.length === 0)) { %>
                          <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#334155;">—</span>
                        <% } %>
                      </div>
                    <% } else { %>
                      <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#334155;">—</span>
                    <% } %>
                  </td>

                  <td class="py-3">
                    <% if (t.blocked) { %>
                      <span class="badge bg-danger">BLOCKED</span>
                      <% if (t.blockedReason) { %>
                        <div style="font-size:0.65rem; color:#ef4444; margin-top:3px; max-width:160px;">
                          <%= t.blockedReason %>
                        </div>
                      <% } %>
                    <% } else { %>
                      <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#22c55e; letter-spacing:0.1em;">
                        ● PUBLIC
                      </span>
                    <% } %>
                  </td>
                  <td class="py-3">
                    <% if (t.blocked) { %>
                      <form action="/admin/tournaments/<%= t._id %>/unblock?_method=PATCH" method="POST">
                        <button class="btn btn-success btn-sm">
                          <i class="bi bi-eye"></i> Unblock
                        </button>
                      </form>
                    <% } else { %>
                      <button class="btn btn-outline-danger btn-sm"
                        onclick="openBlockModal('<%= t._id %>', '<%= t.title.replace(/'/g, '') %>')">
                        <i class="bi bi-eye-slash"></i> Block
                      </button>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Block Modal -->
  <div class="modal fade" id="blockModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content" style="background:#0a0f1e; border:1px solid rgba(56,189,248,0.2); border-radius:0;">
        <div class="modal-header" style="border-bottom:1px solid rgba(56,189,248,0.1);">
          <h6 class="modal-title fw-bold" style="font-family:'Orbitron',monospace; font-size:0.85rem; color:#ef4444;">
            BLOCK TOURNAMENT
          </h6>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <form id="blockForm" method="POST">
          <input type="hidden" name="_method" value="PATCH"/>
          <div class="modal-body">
            <p style="font-size:0.83rem; color:#94a3b8; margin-bottom:14px;">
              Blocking: <strong id="blockTitle" style="color:#ef4444;"></strong>
            </p>
            <label class="form-label fw-semibold">Reason for blocking</label>
            <textarea name="reason" class="form-control" rows="3"
              placeholder="e.g. Fake tournament, scam, inappropriate content..."></textarea>
          </div>
          <div class="modal-footer" style="border-top:1px solid rgba(56,189,248,0.1);">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-danger btn-sm">Confirm Block</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Tournament Reports Modal -->
  <div class="modal fade" id="tournamentReportsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content" style="background:#0a0f1e; border:1px solid rgba(239,68,68,0.3); border-radius:0;">
        <div class="modal-header" style="border-bottom:1px solid rgba(239,68,68,0.15);">
          <h6 class="modal-title fw-bold" style="font-family:'Orbitron',monospace; font-size:0.85rem; color:#ef4444;">
            RESULT REPORTS — <span id="tournamentReportsTitle"></span>
          </h6>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="d-flex gap-3 mb-3">
            <span style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#ef4444; letter-spacing:0.1em;">
              ⚑ <span id="tournamentReportCount"></span> REPORT(S)
            </span>
            <span style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#22c55e; letter-spacing:0.1em;">
              ✓ <span id="tournamentSupportCount"></span> SUPPORT(S)
            </span>
          </div>
          <div id="tournamentReportsBody"></div>
        </div>
        <div class="modal-footer" style="border-top:1px solid rgba(239,68,68,0.15);">
          <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/scripts') %>
  <script>
    function openBlockModal(tournamentId, title) {
      document.getElementById("blockTitle").textContent = title;
      document.getElementById("blockForm").action = `/admin/tournaments/${tournamentId}/block?_method=PATCH`;
      new bootstrap.Modal(document.getElementById("blockModal")).show();
    }

    function openTournamentReportsModal(title, reportCount, supportCount, reports) {
      document.getElementById("tournamentReportsTitle").textContent = title;
      document.getElementById("tournamentReportCount").textContent = reportCount;
      document.getElementById("tournamentSupportCount").textContent = supportCount;

      let html = "";
      if (reports.length === 0) {
        html = `<p style="font-size:0.83rem; color:#475569;">No report reasons provided.</p>`;
      } else {
        reports.forEach((r, i) => {
          html += `
            <div style="border-bottom:1px solid rgba(239,68,68,0.1); padding:12px 0; ${i === 0 ? 'padding-top:0;' : ''}">
              <div style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#ef4444; letter-spacing:0.15em; margin-bottom:6px;">
                REPORT ${i + 1}
              </div>
              <p style="font-size:0.83rem; color:#94a3b8; margin:0;">
                ${r.reason || "No reason provided."}
              </p>
            </div>
          `;
        });
      }

      document.getElementById("tournamentReportsBody").innerHTML = html;
      new bootstrap.Modal(document.getElementById("tournamentReportsModal")).show();
    }
  </script>
</body>
</html>