<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Verify Email | BattleArena</title>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>
    <div class="row justify-content-center">
      <div class="col-md-4">
        <div class="card shadow border-0 ba-card">
          <div class="card-body p-4">

            <h3 class="mb-1 fw-bold text-center">
              <i class="bi bi-envelope-check text-warning"></i> Verify Email
            </h3>
            <p class="text-center mb-4" style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:#475569; letter-spacing:0.15em;">
              // CHECK YOUR INBOX
            </p>

            <p style="font-size:0.85rem; color:#94a3b8; text-align:center; margin-bottom:6px;">
              We sent a 6-digit OTP to
            </p>
            <p style="font-family:'Share Tech Mono',monospace; font-size:0.85rem; color:var(--cyber-blue); text-align:center; margin-bottom:24px;">
              <%= email %>
            </p>

            <form action="/verify-email" method="POST" id="otpForm" novalidate>
              <div class="mb-3">
                <label class="form-label fw-semibold">Enter OTP</label>
                <input
                  type="text"
                  name="otp"
                  id="otp"
                  class="form-control text-center"
                  maxlength="6"
                  placeholder="_ _ _ _ _ _"
                  autocomplete="one-time-code"
                  style="font-family:'Share Tech Mono',monospace; font-size:1.4rem; letter-spacing:0.3em;"
                  autofocus
                />
                <div class="invalid-feedback">Please enter the 6-digit OTP.</div>
              </div>
              <button class="btn btn-warning w-100 fw-bold py-2">
                Verify & Activate Account
              </button>
            </form>

            <hr style="border-color:rgba(56,189,248,0.1); margin:20px 0;"/>

            <% if (resendCount < 3) { %>
              <form action="/resend-otp" method="POST" class="text-center">
                <p style="font-size:0.78rem; color:#475569; margin-bottom:10px;">
                  Didn't receive it? Check spam or resend.
                  <span style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#334155;">
                    (<%= 3 - resendCount %> resend<%= (3 - resendCount) !== 1 ? 's' : '' %> left)
                  </span>
                </p>
                <button type="submit" class="btn btn-outline-warning btn-sm">
                  <i class="bi bi-arrow-clockwise"></i> Resend OTP
                </button>
              </form>
            <% } else { %>
              <p style="font-size:0.75rem; color:#475569; text-align:center;">
                Maximum resends reached.
                <a href="/register" class="text-warning">Register again</a>
              </p>
            <% } %>

          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/scripts') %>
  <script>
    // OTP input — numbers only, auto-submit at 6 digits
    const otpInput = document.getElementById("otp");
    otpInput.addEventListener("input", function () {
      this.value = this.value.replace(/\D/g, "");
      if (this.value.length === 6) {
        document.getElementById("otpForm").submit();
      }
    });
  </script>
</body>
</html>