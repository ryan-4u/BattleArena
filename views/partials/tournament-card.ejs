<div class="col-md-4">
  <div class="card h-100 shadow-sm border-0 ba-card ba-card-hover">
    <div class="card-body p-3">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <span style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:var(--cyber-blue); letter-spacing:0.18em;">
          <%= t.game.toUpperCase() %>
        </span>
        <span class="badge
          <%= t.status === 'upcoming'  ? 'bg-success'  :
              t.status === 'ongoing'   ? 'bg-warning'  : 'bg-secondary' %>">
          <% if (t.status === 'ongoing') { %>
            <span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#fff; margin-right:4px; animation:pulse 1.5s infinite;"></span>
          <% } %>
          <%= t.status.toUpperCase() %>
        </span>
      </div>
      <h5 class="fw-bold mb-1" style="font-size:0.95rem; line-height:1.3;">
        <%= t.title %>
      </h5>
      <p style="font-size:0.72rem; color:#475569; margin-bottom:8px; font-family:'Share Tech Mono',monospace; letter-spacing:0.08em;">
        <i class="bi bi-people"></i> <%= t.mode.toUpperCase() %>
        &nbsp;/&nbsp;
        <i class="bi bi-person-badge"></i> <%= t.organiser.username %>
      </p>
      <p style="font-size:0.8rem; color:#64748b; margin-bottom:10px; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
        <%= t.description %>
      </p>
      <hr style="margin:10px 0;"/>
      <div class="d-flex justify-content-between" style="font-size:0.72rem;">
        <span style="color:var(--cyber-blue); font-family:'Share Tech Mono',monospace;">
          <i class="bi bi-trophy"></i> <%= t.prizePool %>
        </span>
        <span style="color:#475569; font-family:'Share Tech Mono',monospace;">
          <i class="bi bi-people-fill"></i> <%= t.maxPlayers %> MAX
        </span>
      </div>
      <div style="font-size:0.68rem; color:#334155; font-family:'Share Tech Mono',monospace; margin-top:6px; letter-spacing:0.05em;">
        <i class="bi bi-calendar-event"></i>
        <%= new Date(t.startDate).toLocaleDateString('en-IN', {
          day:'numeric', month:'short', year:'numeric'
        }) %>
      </div>
    </div>
    <div class="card-footer pt-2 pb-3 px-3">
      <a href="/tournaments/<%= t._id %>" class="btn btn-warning btn-sm w-100 fw-bold">
        View Details <i class="bi bi-arrow-right"></i>
      </a>
    </div>
  </div>
</div>