<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <title>BattleArena — Compete. Dominate. Win.</title>
  <link rel="stylesheet" href="/css/landing.css"/>
</head>
<body class="ba-bg">

  <!-- Scanline effect -->
  <div class="scanline"></div>

  <!-- ── NAVBAR ── -->
  <%- include('./partials/navbar') %>

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-7 hero-content">
          <div class="hero-eyebrow">SEASON III — NOW OPEN</div>
          <h1 class="hero-title">
            ENTER THE
            <span class="accent">ARENA</span>
          </h1>
          <p class="hero-sub">
            Organise esports tournaments or compete for glory.
            Apply. Get accepted. Receive room access. Battle.
          </p>
          <div class="hero-cta">
            <% if (currUser) { %>
              <a href="/tournaments" class="btn-hero-primary">
                BROWSE TOURNAMENTS
              </a>
              <a href="/profile" class="btn-hero-secondary">
                MY PROFILE
              </a>
            <% } else { %>
              <a href="/register" class="btn-hero-primary">
                JOIN NOW — FREE
              </a>
              <a href="/tournaments" class="btn-hero-secondary">
                BROWSE TOURNAMENTS
              </a>
            <% } %>
          </div>
        </div>

        <!-- Hero right — live ticker -->
        <div class="col-lg-5 hero-content mt-5 mt-lg-0">
          <div style="border: 1px solid rgba(56,189,248,0.15); padding: 24px; position: relative;">
            <div style="position:absolute; top:0; left:0; width:40px; height:2px; background:var(--cyber-blue);"></div>
            <div style="position:absolute; top:0; right:0; width:40px; height:2px; background:var(--cyber-blue);"></div>
            <p style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:var(--cyber-blue); letter-spacing:0.25em; margin-bottom:16px;">
              // LIVE FEED
            </p>
            <% if (featuredTournaments && featuredTournaments.length > 0) { %>
              <% featuredTournaments.forEach(t => { %>
                <div style="border-bottom: 1px solid rgba(56,189,248,0.08); padding: 12px 0;">
                  <div class="d-flex justify-content-between align-items-start">
                    <div>
                      <div style="font-family:'Rajdhani',sans-serif; font-size:0.9rem; font-weight:700; color:var(--cyber-text);">
                        <%= t.title %>
                      </div>
                      <div style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.1em; margin-top:3px;">
                        <%= t.game.toUpperCase() %> / <%= t.mode.toUpperCase() %>
                      </div>
                    </div>
                    <span style="font-family:'Share Tech Mono',monospace; font-size:0.58rem; padding:3px 8px; border:1px solid;
                      <%= t.status === 'ongoing' ? 'color:#38bdf8; border-color:#38bdf8;' : 'color:#22c55e; border-color:#22c55e;' %>">
                      <%= t.status === 'ongoing' ? '● LIVE' : 'OPEN' %>
                    </span>
                  </div>
                  <div style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:var(--cyber-blue); margin-top:6px;">
                    <%= t.prizePool %> &nbsp;·&nbsp; <%= t.maxPlayers %> slots
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <p style="font-size:0.8rem; color:#334155; font-family:'Share Tech Mono',monospace;">
                No active tournaments right now.
              </p>
            <% } %>
            <a href="/tournaments" style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:var(--cyber-blue); letter-spacing:0.15em; text-decoration:none; display:block; margin-top:14px;">
              VIEW ALL TOURNAMENTS →
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── STATS BAR ── -->
  <section class="stats-bar">
    <div class="container">
      <div class="row g-0 align-items-center">
        <div class="col-6 col-md-3 stat-item">
          <div class="stat-value" data-target="<%= stats.tournaments %>">0</div>
          <div class="stat-label">Tournaments</div>
        </div>
        <div class="col-md-1 d-none d-md-flex stat-divider mx-auto"></div>
        <div class="col-6 col-md-3 stat-item">
          <div class="stat-value" data-target="<%= stats.players %>">0</div>
          <div class="stat-label">Players</div>
        </div>
        <div class="col-md-1 d-none d-md-flex stat-divider mx-auto"></div>
        <div class="col-6 col-md-2 stat-item mt-4 mt-md-0">
          <div class="stat-value" data-target="<%= stats.completed %>">0</div>
          <div class="stat-label">Completed</div>
        </div>
        <div class="col-md-1 d-none d-md-flex stat-divider mx-auto"></div>
        <div class="col-6 col-md-1 stat-item mt-4 mt-md-0">
          <div class="stat-value">₹<span data-target="<%= stats.prizeTotal %>">0</span>K</div>
          <div class="stat-label">Prize Given</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ── -->
  <section class="py-5 mt-4">
    <div class="container">
      <div class="text-center mb-5">
        <p class="section-eyebrow">// THE PROCESS</p>
        <h2 class="section-title">How BattleArena Works</h2>
      </div>
      <div class="row g-4">
        <div class="col-md-3">
          <div class="step-card h-100">
            <div class="step-number">01</div>
            <div class="step-title">Create Account</div>
            <p class="step-desc">Register as a Player or Organiser. Set your in-game username and build your profile.</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="step-card h-100">
            <div class="step-number">02</div>
            <div class="step-title">Find Tournament</div>
            <p class="step-desc">Browse active tournaments. Filter by game, mode, or status. Read rules and prize details.</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="step-card h-100">
            <div class="step-number">03</div>
            <div class="step-title">Apply & Wait</div>
            <p class="step-desc">Submit your application. The organiser reviews and accepts or rejects players manually.</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="step-card h-100">
            <div class="step-number">04</div>
            <div class="step-title">Get Room Access</div>
            <p class="step-desc">Accepted players receive the Room ID and Password directly on the tournament page. Battle!</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── ROLES ── -->
  <section class="py-5">
    <div class="container">
      <div class="text-center mb-5">
        <p class="section-eyebrow">// CHOOSE YOUR PATH</p>
        <h2 class="section-title">Player or Organiser?</h2>
      </div>
      <div class="row g-4 justify-content-center">

        <div class="col-md-5">
          <div class="role-card h-100">
            <i class="bi bi-controller role-icon"></i>
            <div class="role-title">PLAYER</div>
            <p class="role-desc">Compete in tournaments, track your history, and climb the ranks.</p>
            <ul class="role-features">
              <li>Browse all active tournaments</li>
              <li>Apply to join with one click</li>
              <li>Get room access on acceptance</li>
              <li>Track tournaments on your profile</li>
            </ul>
            <a href="/register" class="btn-hero-secondary" style="display:inline-block;">
              JOIN AS PLAYER
            </a>
          </div>
        </div>

        <div class="col-md-5">
          <div class="role-card featured h-100">
            <i class="bi bi-trophy role-icon"></i>
            <div class="role-title">ORGANISER</div>
            <p class="role-desc">Host and manage tournaments. Control who enters your arena.</p>
            <ul class="role-features">
              <li>Create tournaments with full details</li>
              <li>Set rules, prize pool, and entry fee</li>
              <li>Accept or reject applicants</li>
              <li>Manage room credentials securely</li>
            </ul>
            <a href="/register" class="btn-hero-primary" style="display:inline-block;">
              BECOME ORGANISER
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── FOOTER ── -->
  <footer class="ba-footer">
    <div class="container">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        <div class="footer-logo">⬡ BATTLEARENA</div>
        <div class="footer-links d-flex gap-4">
          <a href="/tournaments">Tournaments</a>
          <a href="/register">Register</a>
          <a href="/login">Login</a>
          <a href="https://github.com/ryan-4u/BattleArena" target="_blank">GitHub</a>
        </div>
        <div style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#1e293b; letter-spacing:0.1em;">
          BUILT BY AARYAN AGGRAWA
        </div>
      </div>
    </div>
  </footer>

</body>
</html>