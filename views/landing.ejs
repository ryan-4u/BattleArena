<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>BattleArena — Compete. Dominate. Win.</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;600;700&family=Share+Tech+Mono&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
  <style>
    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      position: relative;
      overflow: hidden;
      padding: 80px 0 60px;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(56,189,248,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(56,189,248,0.04) 1px, transparent 1px);
      background-size: 40px 40px;
      z-index: 0;
    }

    /* Radial glow blobs */
    .hero::after {
      content: '';
      position: absolute;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(56,189,248,0.06) 0%, transparent 70%);
      top: -100px; right: -100px;
      pointer-events: none;
      z-index: 0;
    }

    .hero-content { position: relative; z-index: 1; }

    .hero-eyebrow {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.72rem;
      color: var(--cyber-blue);
      letter-spacing: 0.35em;
      text-transform: uppercase;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .hero-eyebrow::before {
      content: '';
      display: inline-block;
      width: 30px; height: 1px;
      background: var(--cyber-blue);
    }

    .hero-title {
      font-family: 'Orbitron', monospace;
      font-size: clamp(2.5rem, 7vw, 5rem);
      font-weight: 900;
      line-height: 1;
      color: #fff;
      margin-bottom: 8px;
      text-shadow: 0 0 60px rgba(56,189,248,0.15);
    }

    .hero-title .accent {
      color: var(--cyber-blue);
      display: block;
      text-shadow: 0 0 40px rgba(56,189,248,0.5);
    }

    .hero-sub {
      font-family: 'Rajdhani', sans-serif;
      font-size: 1.15rem;
      color: #64748b;
      letter-spacing: 0.08em;
      margin: 20px 0 36px;
      max-width: 480px;
      line-height: 1.6;
    }

    .hero-cta {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    .btn-hero-primary {
      font-family: 'Orbitron', monospace;
      font-size: 0.7rem;
      font-weight: 700;
      color: #050d1a;
      background: var(--cyber-blue);
      border: none;
      padding: 14px 32px;
      letter-spacing: 0.12em;
      clip-path: polygon(10px 0%, 100% 0%, calc(100% - 10px) 100%, 0% 100%);
      text-decoration: none;
      transition: box-shadow 0.25s, background 0.2s;
      display: inline-block;
    }

    .btn-hero-primary:hover {
      box-shadow: 0 0 30px rgba(56,189,248,0.5);
      background: #7dd3fc;
      color: #050d1a;
    }

    .btn-hero-secondary {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.7rem;
      color: var(--cyber-blue);
      background: transparent;
      border: 1px solid rgba(56,189,248,0.4);
      padding: 13px 28px;
      letter-spacing: 0.12em;
      text-decoration: none;
      transition: all 0.2s;
      display: inline-block;
    }

    .btn-hero-secondary:hover {
      background: rgba(56,189,248,0.08);
      border-color: var(--cyber-blue);
      color: var(--cyber-blue);
    }

    /* ── STATS BAR ── */
    .stats-bar {
      border-top: 1px solid rgba(56,189,248,0.1);
      border-bottom: 1px solid rgba(56,189,248,0.1);
      padding: 28px 0;
      background: rgba(56,189,248,0.02);
    }

    .stat-item { text-align: center; }

    .stat-value {
      font-family: 'Orbitron', monospace;
      font-size: 2rem;
      font-weight: 900;
      color: var(--cyber-blue);
      line-height: 1;
      margin-bottom: 6px;
    }

    .stat-label {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.62rem;
      color: #334155;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .stat-divider {
      width: 1px;
      background: rgba(56,189,248,0.12);
      align-self: stretch;
    }

    /* ── HOW IT WORKS ── */
    .section-eyebrow {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.65rem;
      color: var(--cyber-blue);
      letter-spacing: 0.3em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .section-title {
      font-family: 'Orbitron', monospace;
      font-size: clamp(1.4rem, 3vw, 2rem);
      font-weight: 700;
      color: #fff;
      margin-bottom: 0;
    }

    .step-card {
      background: rgba(56,189,248,0.02);
      border: 1px solid rgba(56,189,248,0.1);
      padding: 28px 24px;
      position: relative;
      transition: border-color 0.2s, transform 0.2s;
    }

    .step-card:hover {
      border-color: rgba(56,189,248,0.35);
      transform: translateY(-4px);
    }

    .step-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 40px; height: 2px;
      background: var(--cyber-blue);
    }

    .step-number {
      font-family: 'Orbitron', monospace;
      font-size: 2.5rem;
      font-weight: 900;
      color: rgba(56,189,248,0.1);
      line-height: 1;
      margin-bottom: 14px;
    }

    .step-title {
      font-family: 'Rajdhani', sans-serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--cyber-text);
      letter-spacing: 0.05em;
      margin-bottom: 8px;
    }

    .step-desc {
      font-size: 0.83rem;
      color: #475569;
      line-height: 1.6;
      margin: 0;
    }

    /* ── FEATURED TOURNAMENTS ── */
    .tournament-preview-card {
      background: rgba(56,189,248,0.02);
      border: 1px solid rgba(56,189,248,0.1);
      padding: 20px;
      position: relative;
      transition: all 0.2s;
    }

    .tournament-preview-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 30px; height: 2px;
      background: var(--cyber-blue);
    }

    .tournament-preview-card:hover {
      border-color: rgba(56,189,248,0.35);
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(56,189,248,0.08);
    }

    /* ── ROLES SECTION ── */
    .role-card {
      border: 1px solid rgba(56,189,248,0.12);
      padding: 36px 28px;
      position: relative;
      transition: all 0.25s;
      background: rgba(56,189,248,0.02);
    }

    .role-card.featured {
      border-color: rgba(56,189,248,0.4);
      background: rgba(56,189,248,0.04);
    }

    .role-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 50px; height: 2px;
      background: var(--cyber-blue);
    }

    .role-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 32px rgba(56,189,248,0.1);
    }

    .role-icon {
      font-size: 2rem;
      color: var(--cyber-blue);
      margin-bottom: 16px;
      display: block;
    }

    .role-title {
      font-family: 'Orbitron', monospace;
      font-size: 1rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: 0.1em;
      margin-bottom: 10px;
    }

    .role-desc {
      font-size: 0.82rem;
      color: #475569;
      line-height: 1.6;
      margin-bottom: 20px;
    }

    .role-features {
      list-style: none;
      padding: 0; margin: 0 0 24px;
    }

    .role-features li {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.65rem;
      color: #64748b;
      letter-spacing: 0.1em;
      padding: 5px 0;
      border-bottom: 1px solid rgba(56,189,248,0.06);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .role-features li::before {
      content: '›';
      color: var(--cyber-blue);
      font-size: 1rem;
    }

    /* ── FOOTER ── */
    .ba-footer {
      border-top: 1px solid rgba(56,189,248,0.1);
      padding: 32px 0;
      margin-top: 80px;
    }

    .footer-logo {
      font-family: 'Orbitron', monospace;
      font-size: 1.1rem;
      font-weight: 900;
      color: var(--cyber-blue);
      letter-spacing: 0.15em;
    }

    .footer-links a {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.65rem;
      color: #334155;
      letter-spacing: 0.12em;
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer-links a:hover { color: var(--cyber-blue); }

    /* ── SCAN LINE ANIMATION ── */
    @keyframes scanline {
      0%   { transform: translateY(-100%); }
      100% { transform: translateY(100vh); }
    }

    .scanline {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, rgba(56,189,248,0.15), transparent);
      animation: scanline 8s linear infinite;
      pointer-events: none;
      z-index: 9999;
    }

    /* Counter animation */
    .count-up { display: inline-block; }
  </style>
</head>
<body class="ba-bg">

  <!-- Scanline effect -->
  <div class="scanline"></div>

  <!-- ── NAVBAR ── -->
  <%- include('./partials/navbar') %>

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-7 hero-content">
          <div class="hero-eyebrow">SEASON III — NOW OPEN</div>
          <h1 class="hero-title">
            ENTER THE
            <span class="accent">ARENA</span>
          </h1>
          <p class="hero-sub">
            Organise esports tournaments or compete for glory.
            Apply. Get accepted. Receive room access. Battle.
          </p>
          <div class="hero-cta">
            <% if (currUser) { %>
              <a href="/tournaments" class="btn-hero-primary">
                BROWSE TOURNAMENTS
              </a>
              <a href="/profile" class="btn-hero-secondary">
                MY PROFILE
              </a>
            <% } else { %>
              <a href="/register" class="btn-hero-primary">
                JOIN NOW — FREE
              </a>
              <a href="/tournaments" class="btn-hero-secondary">
                BROWSE TOURNAMENTS
              </a>
            <% } %>
          </div>
        </div>

        <!-- Hero right — live ticker -->
        <div class="col-lg-5 hero-content mt-5 mt-lg-0">
          <div style="border: 1px solid rgba(56,189,248,0.15); padding: 24px; position: relative;">
            <div style="position:absolute; top:0; left:0; width:40px; height:2px; background:var(--cyber-blue);"></div>
            <div style="position:absolute; top:0; right:0; width:40px; height:2px; background:var(--cyber-blue);"></div>
            <p style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:var(--cyber-blue); letter-spacing:0.25em; margin-bottom:16px;">
              // LIVE FEED
            </p>
            <% if (featuredTournaments && featuredTournaments.length > 0) { %>
              <% featuredTournaments.forEach(t => { %>
                <div style="border-bottom: 1px solid rgba(56,189,248,0.08); padding: 12px 0;">
                  <div class="d-flex justify-content-between align-items-start">
                    <div>
                      <div style="font-family:'Rajdhani',sans-serif; font-size:0.9rem; font-weight:700; color:var(--cyber-text);">
                        <%= t.title %>
                      </div>
                      <div style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.1em; margin-top:3px;">
                        <%= t.game.toUpperCase() %> / <%= t.mode.toUpperCase() %>
                      </div>
                    </div>
                    <span style="font-family:'Share Tech Mono',monospace; font-size:0.58rem; padding:3px 8px; border:1px solid;
                      <%= t.status === 'ongoing' ? 'color:#38bdf8; border-color:#38bdf8;' : 'color:#22c55e; border-color:#22c55e;' %>">
                      <%= t.status === 'ongoing' ? '● LIVE' : 'OPEN' %>
                    </span>
                  </div>
                  <div style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:var(--cyber-blue); margin-top:6px;">
                    <%= t.prizePool %> &nbsp;·&nbsp; <%= t.maxPlayers %> slots
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <p style="font-size:0.8rem; color:#334155; font-family:'Share Tech Mono',monospace;">
                No active tournaments right now.
              </p>
            <% } %>
            <a href="/tournaments" style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:var(--cyber-blue); letter-spacing:0.15em; text-decoration:none; display:block; margin-top:14px;">
              VIEW ALL TOURNAMENTS →
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── STATS BAR ── -->
  <section class="stats-bar">
    <div class="container">
      <div class="row g-0 align-items-center">
        <div class="col-6 col-md-3 stat-item">
          <div class="stat-value" data-target="<%= stats.tournaments %>">0</div>
          <div class="stat-label">Tournaments</div>
        </div>
        <div class="col-md-1 d-none d-md-flex stat-divider mx-auto"></div>
        <div class="col-6 col-md-3 stat-item">
          <div class="stat-value" data-target="<%= stats.players %>">0</div>
          <div class="stat-label">Players</div>
        </div>
        <div class="col-md-1 d-none d-md-flex stat-divider mx-auto"></div>
        <div class="col-6 col-md-2 stat-item mt-4 mt-md-0">
          <div class="stat-value" data-target="<%= stats.completed %>">0</div>
          <div class="stat-label">Completed</div>
        </div>
        <div class="col-md-1 d-none d-md-flex stat-divider mx-auto"></div>
        <div class="col-6 col-md-1 stat-item mt-4 mt-md-0">
          <div class="stat-value">₹<span data-target="<%= stats.prizeTotal %>">0</span>K</div>
          <div class="stat-label">Prize Given</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ── -->
  <section class="py-5 mt-4">
    <div class="container">
      <div class="text-center mb-5">
        <p class="section-eyebrow">// THE PROCESS</p>
        <h2 class="section-title">How BattleArena Works</h2>
      </div>
      <div class="row g-4">
        <div class="col-md-3">
          <div class="step-card h-100">
            <div class="step-number">01</div>
            <div class="step-title">Create Account</div>
            <p class="step-desc">Register as a Player or Organiser. Set your in-game username and build your profile.</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="step-card h-100">
            <div class="step-number">02</div>
            <div class="step-title">Find Tournament</div>
            <p class="step-desc">Browse active tournaments. Filter by game, mode, or status. Read rules and prize details.</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="step-card h-100">
            <div class="step-number">03</div>
            <div class="step-title">Apply & Wait</div>
            <p class="step-desc">Submit your application. The organiser reviews and accepts or rejects players manually.</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="step-card h-100">
            <div class="step-number">04</div>
            <div class="step-title">Get Room Access</div>
            <p class="step-desc">Accepted players receive the Room ID and Password directly on the tournament page. Battle!</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── ROLES ── -->
  <section class="py-5">
    <div class="container">
      <div class="text-center mb-5">
        <p class="section-eyebrow">// CHOOSE YOUR PATH</p>
        <h2 class="section-title">Player or Organiser?</h2>
      </div>
      <div class="row g-4 justify-content-center">

        <div class="col-md-5">
          <div class="role-card h-100">
            <i class="bi bi-controller role-icon"></i>
            <div class="role-title">PLAYER</div>
            <p class="role-desc">Compete in tournaments, track your history, and climb the ranks.</p>
            <ul class="role-features">
              <li>Browse all active tournaments</li>
              <li>Apply to join with one click</li>
              <li>Get room access on acceptance</li>
              <li>Track tournaments on your profile</li>
            </ul>
            <a href="/register" class="btn-hero-secondary" style="display:inline-block;">
              JOIN AS PLAYER
            </a>
          </div>
        </div>

        <div class="col-md-5">
          <div class="role-card featured h-100">
            <i class="bi bi-trophy role-icon"></i>
            <div class="role-title">ORGANISER</div>
            <p class="role-desc">Host and manage tournaments. Control who enters your arena.</p>
            <ul class="role-features">
              <li>Create tournaments with full details</li>
              <li>Set rules, prize pool, and entry fee</li>
              <li>Accept or reject applicants</li>
              <li>Manage room credentials securely</li>
            </ul>
            <a href="/register" class="btn-hero-primary" style="display:inline-block;">
              BECOME ORGANISER
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── FOOTER ── -->
  <footer class="ba-footer">
    <div class="container">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        <div class="footer-logo">⬡ BATTLEARENA</div>
        <div class="footer-links d-flex gap-4">
          <a href="/tournaments">Tournaments</a>
          <a href="/register">Register</a>
          <a href="/login">Login</a>
          <a href="https://github.com/ryan-4u/BattleArena" target="_blank">GitHub</a>
        </div>
        <div style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#1e293b; letter-spacing:0.1em;">
          BUILT BY AARYAN AGGRAWA
        </div>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Count-up animation for stats
    const counters = document.querySelectorAll("[data-target]");
    const speed = 120;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        const target = parseInt(el.getAttribute("data-target"));
        if (target === 0) { el.textContent = "0"; return; }
        let count = 0;
        const step = Math.ceil(target / speed);
        const timer = setInterval(() => {
          count += step;
          if (count >= target) { el.textContent = target; clearInterval(timer); }
          else el.textContent = count;
        }, 16);
        observer.unobserve(el);
      });
    }, { threshold: 0.3 });

    counters.forEach(c => observer.observe(c));
  </script>
</body>
</html>