<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Tournaments | BattleArena</title>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>

    <div class="d-flex justify-content-between align-items-center mb-1">
      <div>
        <p class="cyber-tag-line mb-1">// ACTIVE ARENA</p>
        <h2 class="fw-bold mb-0">Tournaments</h2>
      </div>
      <% if (currUser && (currUser.role === 'organiser' || currUser.role === 'admin')) { %>
        <a href="/tournaments/new" class="btn btn-warning fw-bold">
          <i class="bi bi-plus-lg"></i> Create Tournament
        </a>
      <% } %>
    </div>

    <hr class="mb-4"/>

    <!-- Search & Filter -->
    <form action="/tournaments" method="GET" class="row g-2 mb-3" novalidate>
      <div class="col-md-5">
        <input type="text" name="search" class="form-control"
          placeholder="Search by title..." value="<%= query.search || '' %>"/>
      </div>
      <div class="col-md-3">
        <input type="text" name="game" class="form-control"
          placeholder="Filter by game..." value="<%= query.game || '' %>"/>
      </div>
      <div class="col-md-2">
        <select name="status" class="form-select">
          <option value="">All Status</option>
          <option value="upcoming"  <%= query.status === 'upcoming'  ? 'selected' : '' %>>Upcoming</option>
          <option value="ongoing"   <%= query.status === 'ongoing'   ? 'selected' : '' %>>Ongoing</option>
          <option value="completed" <%= query.status === 'completed' ? 'selected' : '' %>>Completed</option>
        </select>
      </div>
      <div class="col-md-1">
        <button type="submit" class="btn btn-outline-warning w-100" title="Search">
          <i class="bi bi-search"></i>
        </button>
      </div>
      <div class="col-md-1">
        <a href="/tournaments" class="btn btn-outline-secondary w-100" title="Clear filters">
          <i class="bi bi-x-lg"></i>
        </a>
      </div>
    </form>

    <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#475569; letter-spacing:0.15em; margin-bottom:16px;">
      <%= tournaments.length %> TOURNAMENT<%= tournaments.length !== 1 ? 'S' : '' %> FOUND
    </p>

    <!-- Cards -->
    <% if (tournaments.length === 0) { %>
      <div class="text-center py-5">
        <i class="bi bi-controller display-1" style="color:#1e3a5f;"></i>
        <p class="mt-3" style="font-family:'Share Tech Mono',monospace; font-size:0.8rem; color:#475569; letter-spacing:0.15em;">
          NO TOURNAMENTS FOUND
        </p>
        <% if (currUser && (currUser.role === 'organiser' || currUser.role === 'admin')) { %>
          <a href="/tournaments/new" class="btn btn-warning mt-2">Create the first one</a>
        <% } %>
      </div>
    <% } else { %>

      <%
        const ongoingList   = tournaments.filter(t => t.status === 'ongoing');
        const upcomingList  = tournaments.filter(t => t.status === 'upcoming');
        const completedList = tournaments.filter(t => t.status === 'completed');

        function renderCards(list) { return list; }
      %>

      <!-- ONGOING -->
      <% if (ongoingList.length > 0) { %>
        <div class="mb-2">
          <p style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:#38bdf8; letter-spacing:0.25em; margin-bottom:14px;">
            <span style="display:inline-block; width:7px; height:7px; border-radius:50%; background:#38bdf8; margin-right:6px; animation: pulse 1.5s infinite;"></span>
            LIVE NOW — <%= ongoingList.length %> TOURNAMENT<%= ongoingList.length !== 1 ? 'S' : '' %>
          </p>
        </div>
        <div class="row g-4 mb-5">
          <% for (let t of ongoingList) { %>
            <%- include('../partials/tournament-card', { t }) %>
          <% } %>
        </div>
      <% } %>

      <!-- UPCOMING -->
      <% if (upcomingList.length > 0) { %>
        <div class="mb-2">
          <p style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:#22c55e; letter-spacing:0.25em; margin-bottom:14px;">
            ⬡ UPCOMING — <%= upcomingList.length %> TOURNAMENT<%= upcomingList.length !== 1 ? 'S' : '' %>
          </p>
        </div>
        <div class="row g-4 mb-5">
          <% for (let t of upcomingList) { %>
            <%- include('../partials/tournament-card', { t }) %>
          <% } %>
        </div>
      <% } %>

      <!-- COMPLETED -->
      <% if (completedList.length > 0) { %>
        <div class="mb-2">
          <p style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:#475569; letter-spacing:0.25em; margin-bottom:14px;">
            ✓ COMPLETED — <%= completedList.length %> TOURNAMENT<%= completedList.length !== 1 ? 'S' : '' %>
          </p>
        </div>
        <div class="row g-4 mb-5">
          <% for (let t of completedList) { %>
            <%- include('../partials/tournament-card', { t }) %>
          <% } %>
        </div>
      <% } %>

    <% } %>

  </div>

  <style>
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%       { opacity: 0.4; transform: scale(1.4); }
    }
  </style>

  <%- include('../partials/scripts') %>
</body>
</html>