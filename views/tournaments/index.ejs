<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Tournaments | BattleArena</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>

    <div class="d-flex justify-content-between align-items-center mb-1">
      <div>
        <p class="cyber-tag-line mb-1">// ACTIVE ARENA</p>
        <h2 class="fw-bold mb-0">Tournaments</h2>
      </div>
      <% if (currUser && currUser.role === 'organiser') { %>
        <a href="/tournaments/new" class="btn btn-warning fw-bold">
          <i class="bi bi-plus-lg"></i> Create Tournament
        </a>
      <% } %>
    </div>

    <hr class="mb-4"/>

    <!-- Search & Filter -->
    <form action="/tournaments" method="GET" class="row g-2 mb-3" novalidate>
      <div class="col-md-5">
        <input type="text" name="search" class="form-control"
          placeholder="Search by title..." value="<%= query.search || '' %>"/>
      </div>
      <div class="col-md-3">
        <input type="text" name="game" class="form-control"
          placeholder="Filter by game..." value="<%= query.game || '' %>"/>
      </div>
      <div class="col-md-2">
        <select name="status" class="form-select">
          <option value="">All Status</option>
          <option value="upcoming"  <%= query.status === 'upcoming'  ? 'selected' : '' %>>Upcoming</option>
          <option value="ongoing"   <%= query.status === 'ongoing'   ? 'selected' : '' %>>Ongoing</option>
          <option value="completed" <%= query.status === 'completed' ? 'selected' : '' %>>Completed</option>
        </select>
      </div>
      <div class="col-md-1">
        <button type="submit" class="btn btn-outline-warning w-100" title="Search">
          <i class="bi bi-search"></i>
        </button>
      </div>
      <div class="col-md-1">
        <a href="/tournaments" class="btn btn-outline-secondary w-100" title="Clear filters">
          <i class="bi bi-x-lg"></i>
        </a>
      </div>
    </form>

    <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#475569; letter-spacing:0.15em; margin-bottom:16px;">
      <%= tournaments.length %> TOURNAMENT<%= tournaments.length !== 1 ? 'S' : '' %> FOUND
    </p>

    <!-- Cards -->
    <% if (tournaments.length === 0) { %>
      <div class="text-center py-5">
        <i class="bi bi-controller display-1" style="color:#1e3a5f;"></i>
        <p class="mt-3" style="font-family:'Share Tech Mono',monospace; font-size:0.8rem; color:#475569; letter-spacing:0.15em;">
          NO TOURNAMENTS FOUND
        </p>
        <% if (currUser && currUser.role === 'organiser') { %>
          <a href="/tournaments/new" class="btn btn-warning mt-2">Create the first one</a>
        <% } %>
      </div>
    <% } else { %>
      <div class="row g-4">
        <% for (let t of tournaments) { %>
          <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 ba-card ba-card-hover">
              <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <span style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:var(--cyber-blue); letter-spacing:0.18em;">
                    <%= t.game.toUpperCase() %>
                  </span>
                  <span class="badge
                    <%= t.status === 'upcoming'  ? 'bg-success'  :
                        t.status === 'ongoing'   ? 'bg-warning'  : 'bg-secondary' %>">
                    <%= t.status.toUpperCase() %>
                  </span>
                </div>
                <h5 class="fw-bold mb-1" style="font-size:0.95rem; line-height:1.3;">
                  <%= t.title %>
                </h5>
                <p style="font-size:0.72rem; color:#475569; margin-bottom:8px; font-family:'Share Tech Mono',monospace; letter-spacing:0.08em;">
                  <i class="bi bi-people"></i> <%= t.mode.toUpperCase() %>
                  &nbsp;/&nbsp;
                  <i class="bi bi-person-badge"></i> <%= t.organiser.username %>
                </p>
                <p style="font-size:0.8rem; color:#64748b; margin-bottom:10px; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                  <%= t.description %>
                </p>
                <hr style="margin:10px 0;"/>
                <div class="d-flex justify-content-between" style="font-size:0.72rem;">
                  <span style="color:var(--cyber-blue); font-family:'Share Tech Mono',monospace;">
                    <i class="bi bi-trophy"></i> <%= t.prizePool %>
                  </span>
                  <span style="color:#475569; font-family:'Share Tech Mono',monospace;">
                    <i class="bi bi-people-fill"></i> <%= t.maxPlayers %> MAX
                  </span>
                </div>
                <div style="font-size:0.68rem; color:#334155; font-family:'Share Tech Mono',monospace; margin-top:6px; letter-spacing:0.05em;">
                  <i class="bi bi-calendar-event"></i>
                  <%= new Date(t.startDate).toLocaleDateString('en-IN', {
                    day:'numeric', month:'short', year:'numeric'
                  }) %>
                </div>
              </div>
              <div class="card-footer pt-2 pb-3 px-3">
                <a href="/tournaments/<%= t._id %>" class="btn btn-warning btn-sm w-100 fw-bold">
                  View Details <i class="bi bi-arrow-right"></i>
                </a>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>

  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>