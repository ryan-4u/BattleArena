<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Tournaments | BattleArena</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="fw-bold mb-0"><i class="bi bi-trophy-fill text-warning"></i> Tournaments</h2>
      <% if (currUser && currUser.role === "organiser") { %>
        <a href="/tournaments/new" class="btn btn-warning fw-bold">
          <i class="bi bi-plus-lg"></i> Create Tournament
        </a>
      <% } %>
    </div>

    <!-- Search & Filter -->
    <form action="/tournaments" method="GET" class="row g-2 mb-4">
      <div class="col-md-5">
        <input type="text" name="search" class="form-control" placeholder="Search by title..." value="<%= query.search || '' %>"/>
      </div>
      <div class="col-md-3">
        <input type="text" name="game" class="form-control" placeholder="Filter by game..." value="<%= query.game || '' %>"/>
      </div>
      <div class="col-md-2">
        <select name="status" class="form-select">
          <option value="">All Status</option>
          <option value="upcoming" <%= query.status === 'upcoming' ? 'selected' : '' %>>Upcoming</option>
          <option value="ongoing" <%= query.status === 'ongoing' ? 'selected' : '' %>>Ongoing</option>
          <option value="completed" <%= query.status === 'completed' ? 'selected' : '' %>>Completed</option>
        </select>
      </div>
      <div class="col-md-2">
        <button class="btn btn-outline-warning w-100">
          <i class="bi bi-search"></i> Search
        </button>
      </div>
    </form>

    <!-- Tournament Cards -->
    <% if (tournaments.length === 0) { %>
      <div class="text-center py-5 text-muted">
        <i class="bi bi-controller display-1"></i>
        <p class="mt-3 fs-5">No tournaments found.</p>
      </div>
    <% } else { %>
      <div class="row g-4">
        <% for (let t of tournaments) { %>
          <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 ba-card ba-card-hover">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <h5 class="fw-bold mb-0"><%= t.title %></h5>
                  <span class="badge
                    <%= t.status === 'upcoming' ? 'bg-success' : t.status === 'ongoing' ? 'bg-warning text-dark' : 'bg-secondary' %>">
                    <%= t.status %>
                  </span>
                </div>
                <p class="text-muted small mb-2">
                  <i class="bi bi-controller"></i> <%= t.game %> &nbsp;|&nbsp;
                  <i class="bi bi-people"></i> <%= t.mode %>
                </p>
                <p class="small mb-2 text-truncate"><%= t.description %></p>
                <hr class="my-2"/>
                <div class="d-flex justify-content-between small text-muted">
                  <span><i class="bi bi-trophy"></i> <%= t.prizePool %></span>
                  <span><i class="bi bi-people-fill"></i> <%= t.maxPlayers %> max</span>
                </div>
                <div class="mt-2 small text-muted">
                  <i class="bi bi-calendar-event"></i>
                  <%= new Date(t.startDate).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
                </div>
              </div>
              <div class="card-footer bg-transparent border-0 pt-0">
                <a href="/tournaments/<%= t._id %>" class="btn btn-warning btn-sm w-100 fw-bold">
                  View Details <i class="bi bi-arrow-right"></i>
                </a>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>