<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= tournament.title %> | BattleArena</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>

    <div class="row g-4">
      <!-- Main Info -->
      <div class="col-md-8">
        <div class="card shadow border-0 ba-card mb-4">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start">
              <h2 class="fw-bold"><%= tournament.title %></h2>
              <span class="badge fs-6
                <%= tournament.status === 'upcoming' ? 'bg-success' : tournament.status === 'ongoing' ? 'bg-warning text-dark' : 'bg-secondary' %>">
                <%= tournament.status %>
              </span>
            </div>

            <p class="text-muted">
              <i class="bi bi-controller"></i> <strong><%= tournament.game %></strong> &nbsp;|&nbsp;
              <i class="bi bi-people"></i> <%= tournament.mode %> &nbsp;|&nbsp;
              <i class="bi bi-person-badge"></i> Organised by
              <a href="/profile/<%= tournament.organiser._id %>"><%= tournament.organiser.username %></a>
            </p>

            <p><%= tournament.description %></p>

            <hr/>

            <div class="row g-3 text-center">
              <div class="col-6 col-md-3">
                <div class="ba-stat-box">
                  <div class="fs-5 fw-bold text-warning"><%= tournament.prizePool %></div>
                  <div class="small text-muted">Prize Pool</div>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="ba-stat-box">
                  <div class="fs-5 fw-bold text-warning">₹<%= tournament.entryFee %></div>
                  <div class="small text-muted">Entry Fee</div>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="ba-stat-box">
                  <div class="fs-5 fw-bold text-warning"><%= tournament.maxPlayers %></div>
                  <div class="small text-muted">Max Players</div>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="ba-stat-box">
                  <div class="fs-5 fw-bold text-warning">
                    <%= tournament.applicants.filter(a => a.status === 'accepted').length %>
                  </div>
                  <div class="small text-muted">Accepted</div>
                </div>
              </div>
            </div>

            <hr/>

            <div class="row g-2 small text-muted">
              <div class="col-md-6">
                <i class="bi bi-calendar-event text-warning"></i>
                <strong>Start:</strong>
                <%= new Date(tournament.startDate).toLocaleString('en-IN') %>
              </div>
              <div class="col-md-6">
                <i class="bi bi-calendar-x text-warning"></i>
                <strong>Deadline:</strong>
                <%= new Date(tournament.registrationDeadline).toLocaleString('en-IN') %>
              </div>
            </div>

            <% if (tournament.rules) { %>
              <hr/>
              <h6 class="fw-bold"><i class="bi bi-list-check text-warning"></i> Rules</h6>
              <p class="small" style="white-space: pre-line;"><%= tournament.rules %></p>
            <% } %>

            <!-- Room Details — only for accepted players -->
            <% if (isAccepted) { %>
              <hr/>
              <div class="alert alert-success">
                <h6 class="fw-bold"><i class="bi bi-door-open-fill"></i> Room Details</h6>
                <p class="mb-1"><strong>Room ID:</strong> <%= tournament.roomId || 'Not set yet' %></p>
                <p class="mb-0"><strong>Password:</strong> <%= tournament.roomPassword || 'Not set yet' %></p>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Organiser Actions -->
        <% if (currUser && tournament.organiser._id.equals(currUser._id)) { %>
          <div class="d-flex gap-2 mb-4">
            <a href="/tournaments/<%= tournament._id %>/edit" class="btn btn-outline-warning">
              <i class="bi bi-pencil"></i> Edit
            </a>
            <form action="/tournaments/<%= tournament._id %>?_method=DELETE" method="POST"
              onsubmit="return confirm('Delete this tournament?')">
              <button class="btn btn-outline-danger">
                <i class="bi bi-trash"></i> Delete
              </button>
            </form>
          </div>
        <% } %>

        <!-- Apply Button — players only -->
        <% if (currUser && currUser.role === "player") { %>
          <%
            const myApp = tournament.applicants.find(a => a.player && a.player._id.equals(currUser._id));
          %>
          <% if (!myApp) { %>
            <form action="/tournaments/<%= tournament._id %>/apply" method="POST">
              <button class="btn btn-warning fw-bold px-4">
                <i class="bi bi-send"></i> Apply to Join
              </button>
            </form>
          <% } else if (myApp.status === 'pending') { %>
            <div class="alert alert-info">
              <i class="bi bi-hourglass-split"></i> Your application is <strong>pending</strong> review.
            </div>
          <% } else if (myApp.status === 'accepted') { %>
            <div class="alert alert-success">
              <i class="bi bi-check-circle-fill"></i> You've been <strong>accepted</strong>! See room details above.
            </div>
          <% } else { %>
            <div class="alert alert-danger">
              <i class="bi bi-x-circle-fill"></i> Your application was <strong>rejected</strong>.
            </div>
          <% } %>
        <% } %>
      </div>

      <!-- Applicants Panel — organiser only -->
      <div class="col-md-4">
        <% if (currUser && tournament.organiser._id.equals(currUser._id)) { %>
          <div class="card shadow border-0 ba-card">
            <div class="card-body p-3">
              <h6 class="fw-bold mb-3">
                <i class="bi bi-people-fill text-warning"></i>
                Applicants (<%= tournament.applicants.length %>)
              </h6>
              <% if (tournament.applicants.length === 0) { %>
                <p class="text-muted small">No applications yet.</p>
              <% } else { %>
                <% for (let app of tournament.applicants) { %>
                  <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
                    <div>
                      <div class="fw-semibold small">
                        <a href="/profile/<%= app.player._id %>" class="text-decoration-none">
                          <%= app.player.username %>
                        </a>
                      </div>
                      <div class="small text-muted"><%= app.player.gameUsername || 'No IGN' %></div>
                      <span class="badge
                        <%= app.status === 'accepted' ? 'bg-success' : app.status === 'rejected' ? 'bg-danger' : 'bg-secondary' %>">
                        <%= app.status %>
                      </span>
                    </div>
                    <% if (app.status === 'pending') { %>
                      <div class="d-flex flex-column gap-1">
                        <form action="/tournaments/<%= tournament._id %>/applicants/<%= app.player._id %>/accept?_method=PATCH" method="POST">
                          <button class="btn btn-success btn-sm w-100">✓ Accept</button>
                        </form>
                        <form action="/tournaments/<%= tournament._id %>/applicants/<%= app.player._id %>/reject?_method=PATCH" method="POST">
                          <button class="btn btn-danger btn-sm w-100">✗ Reject</button>
                        </form>
                      </div>
                    <% } %>
                  </div>
                <% } %>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>