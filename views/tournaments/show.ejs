<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title><%= tournament.title %> | BattleArena</title>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>

    <!-- Winner Banner -->
    <% if (tournament.status === 'completed' && tournament.winner) { %>
      <div class="mb-4" style="border:1px solid rgba(250,204,21,0.4); background:rgba(250,204,21,0.04); padding:24px; position:relative;">
        <div style="position:absolute; top:0; left:0; width:50px; height:2px; background:#facc15;"></div>
        <div style="position:absolute; top:0; right:0; width:50px; height:2px; background:#facc15;"></div>
        <p style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:#facc15; letter-spacing:0.3em; margin-bottom:10px;">🏆 TOURNAMENT CHAMPION</p>
        <div class="d-flex align-items-center gap-3">
          <div style="width:52px; height:52px; border-radius:50%; background:rgba(250,204,21,0.15); border:2px solid #facc15; display:flex; align-items:center; justify-content:center; font-family:'Orbitron',monospace; font-size:1.3rem; font-weight:900; color:#facc15;">
            <%= tournament.winner.username.charAt(0).toUpperCase() %>
          </div>
          <div>
            <a href="/profile/<%= tournament.winner._id %>" style="font-family:'Orbitron',monospace; font-size:1.1rem; font-weight:900; color:#facc15; text-decoration:none; letter-spacing:0.08em;">
              <%= tournament.winner.username %>
            </a>
            <div style="font-family:'Share Tech Mono',monospace; font-size:0.62rem; color:#78716c; letter-spacing:0.15em; margin-top:3px;">
              WINNER · <%= new Date(tournament.winnerDeclaredAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
            </div>
          </div>
        </div>
        <div class="d-flex gap-3 mt-3">
          <span style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#22c55e; letter-spacing:0.1em;">✓ <%= tournament.resultSupports.length %> SUPPORT<%= tournament.resultSupports.length !== 1 ? 'S' : '' %></span>
          <span style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#ef4444; letter-spacing:0.1em;">⚑ <%= tournament.resultReports.length %> REPORT<%= tournament.resultReports.length !== 1 ? 'S' : '' %></span>
        </div>
        <% if (isAccepted) { %>
          <div class="d-flex gap-2 mt-3">
            <% if (hasResponded) { %>
              <span style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#475569; letter-spacing:0.1em;">You have <%= userResponse %> this result.</span>
            <% } else { %>
              <form action="/tournaments/<%= tournament._id %>/support" method="POST">
                <button class="btn btn-sm btn-outline-success"><i class="bi bi-hand-thumbs-up"></i> Support Result</button>
              </form>
              <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#reportResultModal">
                <i class="bi bi-flag"></i> Report Result
              </button>
            <% } %>
          </div>
        <% } %>
        <div class="mt-3">
          <a href="/tournaments/<%= tournament._id %>/bracket" style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:var(--cyber-blue); letter-spacing:0.15em; text-decoration:none;">
            <i class="bi bi-diagram-3"></i> VIEW FULL BRACKET →
          </a>
        </div>
      </div>
    <% } %>

    <!-- Blocked Warning -->
    <% if (tournament.blocked) { %>
      <div class="alert mb-4" style="background:rgba(239,68,68,0.06); border:1px solid rgba(239,68,68,0.4); border-left-width:4px; border-radius:0;">
        <div style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#ef4444; letter-spacing:0.2em; margin-bottom:6px;">⚠ TOURNAMENT BLOCKED BY ADMIN</div>
        <p style="font-size:0.83rem; color:#fca5a5; margin-bottom:4px;">This tournament has been hidden from public view. Participants cannot register.</p>
        <% if (tournament.blockedReason) { %>
          <p style="font-family:'Share Tech Mono',monospace; font-size:0.72rem; color:#ef4444; margin:0;">REASON: <%= tournament.blockedReason %></p>
        <% } %>
      </div>
    <% } %>

    <div class="row g-4">

      <!-- MAIN INFO -->
      <div class="col-md-8">
        <div class="card shadow border-0 ba-card mb-4">
          <div class="card-body p-4">

            <div class="d-flex justify-content-between align-items-start mb-2">
              <h2 class="fw-bold mb-0"><%= tournament.title %></h2>
              <span class="badge fs-6 <%= tournament.status === 'upcoming' ? 'bg-success' : tournament.status === 'ongoing' ? 'bg-warning' : 'bg-secondary' %>">
                <%= tournament.status.toUpperCase() %>
              </span>
            </div>

            <p class="text-muted mb-3" style="font-family:'Share Tech Mono',monospace; font-size:0.75rem; letter-spacing:0.1em;">
              <i class="bi bi-controller"></i> <%= tournament.game %>
              &nbsp;/&nbsp;
              <i class="bi bi-people"></i> <%= tournament.mode %>
              &nbsp;/&nbsp;
              <i class="bi bi-person-badge"></i>
              <a href="/profile/<%= tournament.organiser._id %>" style="color:var(--cyber-blue);">
                <%= tournament.organiser.username %>
              </a>
            </p>

            <p style="color:#94a3b8; font-size:0.9rem; line-height:1.7;"><%= tournament.description %></p>

            <hr/>

            <!-- Stat Boxes -->
            <div class="row g-3 text-center mb-3">
              <div class="col-6 col-md-3">
                <div class="ba-stat-box">
                  <div class="fs-5 fw-bold"><%= tournament.prizePool %></div>
                  <div class="small">Prize Pool</div>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="ba-stat-box">
                  <div class="fs-5 fw-bold">₹<%= tournament.entryFee %></div>
                  <div class="small">Entry Fee</div>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="ba-stat-box">
                  <div class="fs-5 fw-bold"><%= tournament.maxPlayers %></div>
                  <div class="small">Max Participants</div>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="ba-stat-box">
                  <div class="fs-5 fw-bold"><%= tournament.applicants.filter(a => a.status === 'accepted').length %></div>
                  <div class="small">Accepted</div>
                </div>
              </div>
            </div>

            <!-- Dates -->
            <div class="row g-2 mb-3" style="font-size:0.8rem;">
              <div class="col-md-6">
                <span style="color:var(--cyber-blue); font-family:'Share Tech Mono',monospace; font-size:0.65rem; letter-spacing:0.15em;">START DATE</span><br/>
                <span style="color:#94a3b8;">
                  <%= new Date(tournament.startDate).toLocaleString('en-IN', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                </span>
              </div>
              <div class="col-md-6">
                <span style="color:var(--cyber-blue); font-family:'Share Tech Mono',monospace; font-size:0.65rem; letter-spacing:0.15em;">REGISTRATION CLOSES</span><br/>
                <span style="color:#94a3b8;">
                  <%= new Date(tournament.registrationDeadline).toLocaleString('en-IN', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                </span>
              </div>
            </div>

            <!-- Rules -->
            <% if (tournament.rules) { %>
              <hr/>
              <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:var(--cyber-blue); letter-spacing:0.2em; margin-bottom:10px;">RULES</p>
              <ul class="list-unstyled mb-0">
                <% tournament.rules.split('\n').filter(r => r.trim()).forEach(rule => { %>
                  <li class="d-flex gap-2 mb-2" style="font-size:0.85rem;">
                    <span style="color:var(--cyber-blue); font-family:'Share Tech Mono',monospace; min-width:16px; flex-shrink:0;">›</span>
                    <span style="color:#94a3b8;"><%= rule.replace(/^\d+\.\s*/, '') %></span>
                  </li>
                <% }) %>
              </ul>
            <% } %>

          </div>
        </div>

        <!-- Announcements — visible to accepted players + organiser -->
        <%
          const isOrgView = currUser && tournament.organiser._id.equals(currUser._id);
          const canSeeAnnouncements = isOrgView || isAccepted;
        %>
        <% if (canSeeAnnouncements && (tournament.announcements.length > 0 || isOrgView)) { %>
          <div class="card ba-card mb-4" style="border-color:rgba(250,204,21,0.2);">
            <div class="card-body p-4">
              <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#facc15; letter-spacing:0.2em; margin-bottom:16px;">
                📢 ANNOUNCEMENTS
              </p>

              <!-- Organiser: post new announcement -->
              <% if (isOrgView) { %>
                <form action="/tournaments/<%= tournament._id %>/announcements" method="POST" class="mb-4">
                  <div class="d-flex gap-2">
                    <input type="text" name="text" class="form-control"
                      placeholder="Post an update, schedule change, or important note..."
                      required maxlength="500"/>
                    <button type="submit" class="btn btn-warning fw-bold px-3" style="white-space:nowrap;">
                      <i class="bi bi-megaphone"></i> Post
                    </button>
                  </div>
                </form>
              <% } %>

              <!-- Announcements list -->
              <% if (tournament.announcements.length === 0) { %>
                <p style="font-size:0.82rem; color:#475569; margin:0;">No announcements yet.</p>
              <% } else { %>
                <% tournament.announcements.forEach(ann => { %>
                  <div class="d-flex justify-content-between align-items-start mb-3 pb-3"
                    style="border-bottom:1px solid rgba(250,204,21,0.08);">
                    <div>
                      <p style="font-size:0.88rem; color:#e2e8f0; margin-bottom:4px; line-height:1.6;">
                        <%= ann.text %>
                      </p>
                      <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.1em;">
                        <%= new Date(ann.postedAt).toLocaleString('en-IN', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %>
                      </span>
                    </div>
                    <% if (isOrgView) { %>
                      <form action="/tournaments/<%= tournament._id %>/announcements/<%= ann._id %>?_method=DELETE"
                        method="POST" class="ms-3 flex-shrink-0"
                        onsubmit="return confirm('Remove this announcement?')">
                        <button type="submit" class="btn btn-outline-danger btn-sm" style="font-size:0.7rem; padding:2px 8px;">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    <% } %>
                  </div>
                <% }) %>
              <% } %>
            </div>
          </div>
        <% } %>

        <!-- View Bracket button -->
        <% if (tournament.bracketGenerated) { %>
          <div class="mb-4">
            <a href="/tournaments/<%= tournament._id %>/bracket" class="btn btn-warning fw-bold px-4 py-2">
              <i class="bi bi-diagram-3-fill"></i> View Bracket
            </a>
          </div>
        <% } %>

        
        <!-- Organiser action section — format-aware -->
        <% if (currUser && tournament.organiser._id.equals(currUser._id)) { %>
          <% if (tournament.status === 'ongoing' || (tournament.status === 'upcoming' && new Date() > new Date(tournament.registrationDeadline))) { %>
            <% const acceptedPlayers = tournament.applicants.filter(a => a.status === 'accepted'); %>

            <% if (tournament.tournamentFormat === 'simple') { %>
              <!-- SIMPLE FORMAT: Declare Winner -->
              <div class="card ba-card mb-4" style="border-color:rgba(250,204,21,0.2);">
                <div class="card-body p-4">
                  <% if (tournament.status !== 'completed') { %>
                    <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#facc15; letter-spacing:0.2em; margin-bottom:6px;">// DECLARE WINNER</p>
                    <% if (acceptedPlayers.length > 0) { %>
                      <p style="font-size:0.78rem; color:#475569; margin-bottom:16px;">
                        Select the winner from confirmed participants. Tournament will be marked as completed.
                      </p>
                      <form action="/tournaments/<%= tournament._id %>/declare-winner?_method=PATCH" method="POST"
                        onsubmit="return confirm('Declare this participant as winner? This cannot be undone.')">
                        <div class="row g-2">
                          <div class="col-md-8">
                            <select name="winnerId" class="form-select" required>
                              <option value="">Select winner...</option>
                              <% acceptedPlayers.forEach(app => { %>
                                <option value="<%= app.player._id %>"><%= app.player.username %></option>
                              <% }) %>
                            </select>
                          </div>
                          <div class="col-md-4">
                            <button type="submit" class="btn btn-warning w-100 fw-bold">
                              <i class="bi bi-trophy-fill"></i> Declare Winner
                            </button>
                          </div>
                        </div>
                      </form>
                    <% } else { %>
                      <p style="font-size:0.8rem; color:#475569; margin-bottom:0;">
                        No confirmed participants yet. Accept at least one participant first.
                      </p>
                    <% } %>
                  <% } else { %>
                    <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#22c55e; letter-spacing:0.2em; margin-bottom:0;">✓ TOURNAMENT COMPLETED</p>
                  <% } %>
                </div>
              </div>

            <% } else { %>
              <!-- BRACKET FORMAT: Generate Bracket -->
              <div class="card ba-card mb-4" style="border-color:rgba(56,189,248,0.2);">
                <div class="card-body p-4">
                  <% if (!tournament.bracketGenerated) { %>
                    <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:var(--cyber-blue); letter-spacing:0.2em; margin-bottom:6px;">// BRACKET</p>
                    <% if (acceptedPlayers.length >= 2) { %>
                      <%
                        const n = acceptedPlayers.length;
                        const mainSize = Math.pow(2, Math.floor(Math.log2(n)));
                        const prelimCount = n - mainSize;
                      %>
                      <p style="font-size:0.8rem; color:#475569; margin-bottom:6px;">
                        <strong style="color:#94a3b8;"><%= acceptedPlayers.length %></strong> participants confirmed.
                        <% if (prelimCount > 0) { %>
                          <strong style="color:#f97316;"><%= prelimCount * 2 %></strong> will play a qualifying round first.
                        <% } else { %>
                          Clean draw — no qualifying round needed.
                        <% } %>
                      </p>
                      <p style="font-size:0.75rem; color:#475569; margin-bottom:16px;">This action is permanent and cannot be undone.</p>
                      <form action="/tournaments/<%= tournament._id %>/bracket/generate" method="POST"
                        onsubmit="return confirm('Generate bracket? This cannot be undone.')">
                        <button type="submit" class="btn btn-warning fw-bold px-4">
                          <i class="bi bi-diagram-3-fill"></i> Generate Bracket
                        </button>
                      </form>
                    <% } else { %>
                      <p style="font-size:0.8rem; color:#475569; margin-bottom:0;">Accept at least <strong>2 participants</strong> before generating the bracket.</p>
                    <% } %>
                  <% } else { %>
                    <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#22c55e; letter-spacing:0.2em; margin-bottom:10px;">✓ BRACKET ACTIVE</p>
                    <a href="/tournaments/<%= tournament._id %>/bracket" class="btn btn-warning fw-bold px-4">
                      <i class="bi bi-diagram-3-fill"></i> Manage Bracket
                    </a>
                  <% } %>
                </div>
              </div>
            <% } %>

          <% } else if (tournament.status === 'upcoming') { %>
            <!-- Registration still open — show deadline info -->
            <div class="card ba-card mb-4" style="border-color:rgba(71,85,105,0.2);">
              <div class="card-body p-4">
                <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#475569; letter-spacing:0.2em; margin-bottom:6px;">
                  // <%= tournament.tournamentFormat === 'simple' ? 'WINNER DECLARATION' : 'BRACKET GENERATION' %>
                </p>
                <p style="font-size:0.8rem; color:#475569; margin-bottom:0;">
                  Available after registration closes on
                  <strong style="color:#94a3b8;">
                    <%= new Date(tournament.registrationDeadline).toLocaleString('en-IN', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                  </strong>
                </p>
              </div>
            </div>
          <% } %>
        <% } %>
        

        <!-- Apply Section -->
        <% if (currUser && currUser.role === 'player') { %>
          <%
            const myApp = tournament.applicants.find(
              a => a.player && a.player._id.equals(currUser._id)
            );
          %>
          <% if (!myApp) { %>
            <% if (tournament.status === 'completed') { %>
              <div class="alert alert-info"><i class="bi bi-flag-fill"></i> This tournament has ended.</div>
            <% } else if (tournament.blocked) { %>
              <div class="alert alert-danger"><i class="bi bi-slash-circle"></i> Registration is closed for this tournament.</div>
            <% } else if (tournament.bracketGenerated) { %>
              <div class="alert alert-info"><i class="bi bi-diagram-3"></i> The bracket has been drawn. Registration is now closed.</div>
            <% } else if (tournament.status === 'ongoing') { %>
              <div class="alert alert-warning"><i class="bi bi-lock"></i> This tournament is already underway. Registration is closed.</div>
            <% } else if (new Date() > new Date(tournament.registrationDeadline)) { %>
              <div class="alert alert-warning"><i class="bi bi-clock"></i> Registration deadline has passed.</div>
            <% } else { %>
              <form action="/tournaments/<%= tournament._id %>/apply" method="POST">
                <button class="btn btn-warning fw-bold px-4 py-2"><i class="bi bi-send"></i> Register / Apply</button>
              </form>
            <% } %>
          <% } else if (myApp.status === 'pending') { %>
            <div class="alert alert-info d-flex justify-content-between align-items-center">
              <span><i class="bi bi-hourglass-split"></i> Your registration is <strong>pending</strong> — waiting for organiser review.</span>
              <form action="/tournaments/<%= tournament._id %>/withdraw?_method=DELETE" method="POST"
                onsubmit="return confirm('Withdraw your registration?')">
                <button class="btn btn-outline-danger btn-sm ms-3"><i class="bi bi-x-circle"></i> Withdraw</button>
              </form>
            </div>
          <% } else if (myApp.status === 'accepted') { %>
            <div class="alert alert-success d-flex justify-content-between align-items-center flex-wrap gap-2">
              <span><i class="bi bi-check-circle-fill"></i> You're <strong>confirmed</strong>! Check announcements above for match details.</span>
              <% if (tournament.bracketGenerated) { %>
                <a href="/tournaments/<%= tournament._id %>/bracket" class="btn btn-warning btn-sm fw-bold">
                  <i class="bi bi-diagram-3-fill"></i> View My Matches
                </a>
              <% } %>
            </div>
          <% } else { %>
            <div class="alert alert-danger"><i class="bi bi-x-circle-fill"></i> Your registration was <strong>not accepted</strong>.</div>
          <% } %>
        <% } %>

        <% if (!currUser) { %>
          <div class="alert alert-info">
            <a href="/login" style="color:var(--cyber-blue);">Login</a> to register for this tournament.
          </div>
        <% } %>

      </div>

      <!-- APPLICANTS PANEL — organiser only -->
      <div class="col-md-4">
        <% if (currUser && tournament.organiser._id.equals(currUser._id)) { %>
          <div class="card shadow border-0 ba-card">
            <div class="card-body p-3">
              <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:var(--cyber-blue); letter-spacing:0.2em; margin-bottom:14px;">
                PARTICIPANTS (<%= tournament.applicants.length %>)
              </p>
              <% if (tournament.applicants.length === 0) { %>
                <p class="text-muted small">No registrations yet.</p>
              <% } else { %>
                <% const pending  = tournament.applicants.filter(a => a.status === 'pending'); %>
                <% const accepted = tournament.applicants.filter(a => a.status === 'accepted'); %>
                <% const rejected = tournament.applicants.filter(a => a.status === 'rejected'); %>

                <% if (pending.length > 0) { %>
                  <p style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.15em; margin-bottom:8px;">PENDING (<%= pending.length %>)</p>
                  <% pending.forEach(app => { %>
                    <div class="applicant-row">
                      <div class="d-flex justify-content-between align-items-center">
                        <div>
                          <a href="/profile/<%= app.player._id %>" style="font-size:0.85rem; font-weight:600; color:var(--cyber-text); text-decoration:none;"><%= app.player.username %></a>
                          <div style="font-size:0.7rem; color:#475569;"><%= app.player.gameUsername || 'No username set' %></div>
                        </div>
                        <% if (!tournament.bracketGenerated) { %>
                          <div class="d-flex flex-column gap-1">
                            <form action="/tournaments/<%= tournament._id %>/applicants/<%= app.player._id %>/accept?_method=PATCH" method="POST">
                              <button class="btn btn-success btn-sm w-100">✓ Accept</button>
                            </form>
                            <form action="/tournaments/<%= tournament._id %>/applicants/<%= app.player._id %>/reject?_method=PATCH" method="POST">
                              <button class="btn btn-danger btn-sm w-100">✗ Reject</button>
                            </form>
                          </div>
                        <% } else { %>
                          <span style="font-family:'Share Tech Mono',monospace; font-size:0.58rem; color:#334155; letter-spacing:0.1em;">LOCKED</span>
                        <% } %>
                      </div>
                    </div>
                  <% }) %>
                <% } %>

                <% if (accepted.length > 0) { %>
                  <p style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.15em; margin: 12px 0 8px;">ACCEPTED (<%= accepted.length %>)</p>
                  <% accepted.forEach(app => { %>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <div>
                        <a href="/profile/<%= app.player._id %>" style="font-size:0.82rem; font-weight:600; color:#86efac; text-decoration:none;"><%= app.player.username %></a>
                        <div style="font-size:0.68rem; color:#475569;"><%= app.player.gameUsername || 'No username' %></div>
                      </div>
                      <span class="badge bg-success">CONFIRMED</span>
                    </div>
                  <% }) %>
                <% } %>

                <% if (rejected.length > 0) { %>
                  <p style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.15em; margin: 12px 0 8px;">NOT ACCEPTED (<%= rejected.length %>)</p>
                  <% rejected.forEach(app => { %>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <a href="/profile/<%= app.player._id %>" style="font-size:0.82rem; color:#475569; text-decoration:none;"><%= app.player.username %></a>
                      <span class="badge bg-danger">NOT ACCEPTED</span>
                    </div>
                  <% }) %>
                <% } %>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>

    </div>
  </div>

  <!-- Report Result Modal -->
  <div class="modal fade" id="reportResultModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content" style="background:#0a0f1e; border:1px solid rgba(239,68,68,0.3); border-radius:0;">
        <div class="modal-header" style="border-bottom:1px solid rgba(239,68,68,0.15);">
          <h6 class="modal-title fw-bold" style="font-family:'Orbitron',monospace; font-size:0.85rem; color:#ef4444;">REPORT RESULT</h6>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <form action="/tournaments/<%= tournament._id %>/report" method="POST">
          <div class="modal-body">
            <p style="font-size:0.82rem; color:#94a3b8; margin-bottom:14px;">Tell us why you believe the result is incorrect.</p>
            <label class="form-label fw-semibold" style="font-size:0.78rem;">Reason</label>
            <textarea name="reason" class="form-control" rows="3"
              placeholder="e.g. Wrong winner declared, match didn't take place..."></textarea>
          </div>
          <div class="modal-footer" style="border-top:1px solid rgba(239,68,68,0.15);">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-danger btn-sm">Submit Report</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%- include('../partials/scripts') %>
</body>
</html>