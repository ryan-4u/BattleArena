<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= tournament.title %> | BattleArena</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>
    <!-- Blocked warning — visible to organiser and admin only -->
    <% if (tournament.blocked) { %>
      <div class="alert mb-4" style="background:rgba(239,68,68,0.06); border:1px solid rgba(239,68,68,0.4); border-left-width:4px; border-radius:0;">
        <div style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#ef4444; letter-spacing:0.2em; margin-bottom:6px;">
          ⚠ TOURNAMENT BLOCKED BY ADMIN
        </div>
        <p style="font-size:0.83rem; color:#fca5a5; margin-bottom:4px;">
          This tournament has been hidden from public view and players cannot apply.
        </p>
        <% if (tournament.blockedReason) { %>
          <p style="font-family:'Share Tech Mono',monospace; font-size:0.72rem; color:#ef4444; margin:0;">
            REASON: <%= tournament.blockedReason %>
          </p>
        <% } %>
        <p style="font-size:0.75rem; color:#475569; margin-top:8px; margin-bottom:0;">
          If you believe this is a mistake, contact the platform admin.
        </p>
      </div>
    <% } %>

    <div class="row g-4">

      <!-- MAIN INFO -->
      <div class="col-md-8">
        <div class="card shadow border-0 ba-card mb-4">
          <div class="card-body p-4">

            <div class="d-flex justify-content-between align-items-start mb-2">
              <h2 class="fw-bold mb-0"><%= tournament.title %></h2>
              <span class="badge fs-6
                <%= tournament.status === 'upcoming'  ? 'bg-success'  :
                    tournament.status === 'ongoing'   ? 'bg-warning'  : 'bg-secondary' %>">
                <%= tournament.status.toUpperCase() %>
              </span>
            </div>

            <p class="text-muted mb-3" style="font-family:'Share Tech Mono',monospace; font-size:0.75rem; letter-spacing:0.1em;">
              <i class="bi bi-controller"></i> <%= tournament.game %>
              &nbsp;/&nbsp;
              <i class="bi bi-people"></i> <%= tournament.mode %>
              &nbsp;/&nbsp;
              <i class="bi bi-person-badge"></i>
              <a href="/profile/<%= tournament.organiser._id %>" style="color:var(--cyber-blue);">
                <%= tournament.organiser.username %>
              </a>
            </p>

            <p style="color:#94a3b8; font-size:0.9rem; line-height:1.7;">
              <%= tournament.description %>
            </p>

            <hr/>

            <!-- Stat Boxes -->
            <div class="row g-3 text-center mb-3">
              <div class="col-6 col-md-3">
                <div class="ba-stat-box">
                  <div class="fs-5 fw-bold"><%= tournament.prizePool %></div>
                  <div class="small">Prize Pool</div>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="ba-stat-box">
                  <div class="fs-5 fw-bold">₹<%= tournament.entryFee %></div>
                  <div class="small">Entry Fee</div>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="ba-stat-box">
                  <div class="fs-5 fw-bold"><%= tournament.maxPlayers %></div>
                  <div class="small">Max Players</div>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="ba-stat-box">
                  <div class="fs-5 fw-bold">
                    <%= tournament.applicants.filter(a => a.status === 'accepted').length %>
                  </div>
                  <div class="small">Accepted</div>
                </div>
              </div>
            </div>

            <!-- Dates -->
            <div class="row g-2 mb-3" style="font-size:0.8rem;">
              <div class="col-md-6">
                <span style="color:var(--cyber-blue); font-family:'Share Tech Mono',monospace; font-size:0.65rem; letter-spacing:0.15em;">START DATE</span><br/>
                <span style="color:#94a3b8;">
                  <%= new Date(tournament.startDate).toLocaleString('en-IN', {
                    day:'numeric', month:'short', year:'numeric',
                    hour:'2-digit', minute:'2-digit'
                  }) %>
                </span>
              </div>
              <div class="col-md-6">
                <span style="color:var(--cyber-blue); font-family:'Share Tech Mono',monospace; font-size:0.65rem; letter-spacing:0.15em;">REGISTRATION DEADLINE</span><br/>
                <span style="color:#94a3b8;">
                  <%= new Date(tournament.registrationDeadline).toLocaleString('en-IN', {
                    day:'numeric', month:'short', year:'numeric',
                    hour:'2-digit', minute:'2-digit'
                  }) %>
                </span>
              </div>
            </div>

            <!-- Rules point-wise -->
            <% if (tournament.rules) { %>
              <hr/>
              <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:var(--cyber-blue); letter-spacing:0.2em; margin-bottom:10px;">
                RULES
              </p>
              <ul class="list-unstyled mb-0">
                <% tournament.rules.split('\n').filter(r => r.trim()).forEach(rule => { %>
                  <li class="d-flex gap-2 mb-2" style="font-size:0.85rem;">
                    <span style="color:var(--cyber-blue); font-family:'Share Tech Mono',monospace; min-width:16px; flex-shrink:0;">›</span>
                    <span style="color:#94a3b8;"><%= rule.replace(/^\d+\.\s*/, '') %></span>
                  </li>
                <% }) %>
              </ul>
            <% } %>

            <!-- Room Details — accepted players only -->
            <% if (isAccepted) { %>
              <hr/>
              <div class="alert alert-success mt-2">
                <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; letter-spacing:0.2em; margin-bottom:10px;">
                  ROOM DETAILS
                </p>
                <div class="row g-2">
                  <div class="col-md-6">
                    <span style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#86efac; letter-spacing:0.1em;">ROOM ID</span><br/>
                    <strong style="font-size:1rem; letter-spacing:0.1em;">
                      <%= tournament.roomId || 'Not set yet' %>
                    </strong>
                  </div>
                  <div class="col-md-6">
                    <span style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#86efac; letter-spacing:0.1em;">PASSWORD</span><br/>
                    <strong style="font-size:1rem; letter-spacing:0.1em;">
                      <%= tournament.roomPassword || 'Not set yet' %>
                    </strong>
                  </div>
                </div>
              </div>
            <% } %>

          </div>
        </div>

        <!-- Organiser Actions -->
        <% if (currUser && tournament.organiser._id.equals(currUser._id)) { %>
          <div class="d-flex gap-2 mb-4">
            <a href="/tournaments/<%= tournament._id %>/edit" class="btn btn-outline-warning">
              <i class="bi bi-pencil"></i> Edit Tournament
            </a>
            <form action="/tournaments/<%= tournament._id %>?_method=DELETE" method="POST"
              onsubmit="return confirm('Delete this tournament? This cannot be undone.')">
              <button class="btn btn-outline-danger">
                <i class="bi bi-trash"></i> Delete
              </button>
            </form>
          </div>
        <% } %>

        <!-- Apply Section -->
        <% if (currUser && currUser.role === 'player') { %>
          <%
            const myApp = tournament.applicants.find(
              a => a.player && a.player._id.equals(currUser._id)
            );
          %>
          <% if (!myApp) { %>
            <% if (tournament.status === 'completed') { %>
              <div class="alert alert-info">
                <i class="bi bi-flag-fill"></i> This tournament has ended.
              </div>
            <% } else if (tournament.blocked) { %>
              <div class="alert alert-danger">
                <i class="bi bi-slash-circle"></i> Applications are currently closed for this tournament.
              </div>
            <% } else { %>
              <form action="/tournaments/<%= tournament._id %>/apply" method="POST">
                <button class="btn btn-warning fw-bold px-4 py-2">
                  <i class="bi bi-send"></i> Apply to Join
                </button>
              </form>
            <% } %>
          <% } else if (myApp.status === 'pending') { %>
            <div class="alert alert-info">
              <i class="bi bi-hourglass-split"></i>
              Your application is <strong>pending</strong> — waiting for organiser review.
            </div>
          <% } else if (myApp.status === 'accepted') { %>
            <div class="alert alert-success">
              <i class="bi bi-check-circle-fill"></i>
              You've been <strong>accepted</strong>! Room details are shown above.
            </div>
          <% } else { %>
            <div class="alert alert-danger">
              <i class="bi bi-x-circle-fill"></i>
              Your application was <strong>rejected</strong>.
            </div>
          <% } %>
        <% } %>

        <% if (!currUser) { %>
          <div class="alert alert-info">
            <a href="/login" style="color:var(--cyber-blue);">Login</a> to apply for this tournament.
          </div>
        <% } %>
      </div>

      <!-- APPLICANTS PANEL — organiser only -->
      <div class="col-md-4">
        <% if (currUser && tournament.organiser._id.equals(currUser._id)) { %>
          <div class="card shadow border-0 ba-card">
            <div class="card-body p-3">
              <p style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:var(--cyber-blue); letter-spacing:0.2em; margin-bottom:14px;">
                APPLICANTS (<%= tournament.applicants.length %>)
              </p>

              <% if (tournament.applicants.length === 0) { %>
                <p class="text-muted small">No applications yet.</p>
              <% } else { %>
                <% const pending  = tournament.applicants.filter(a => a.status === 'pending');  %>
                <% const accepted = tournament.applicants.filter(a => a.status === 'accepted'); %>
                <% const rejected = tournament.applicants.filter(a => a.status === 'rejected'); %>

                <% if (pending.length > 0) { %>
                  <p style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.15em; margin-bottom:8px;">
                    PENDING (<%= pending.length %>)
                  </p>
                  <% pending.forEach(app => { %>
                    <div class="applicant-row">
                      <div class="d-flex justify-content-between align-items-center">
                        <div>
                          <a href="/profile/<%= app.player._id %>"
                            style="font-size:0.85rem; font-weight:600; color:var(--cyber-text); text-decoration:none;">
                            <%= app.player.username %>
                          </a>
                          <div style="font-size:0.7rem; color:#475569;">
                            <%= app.player.gameUsername || 'No IGN set' %>
                          </div>
                        </div>
                        <div class="d-flex flex-column gap-1">
                          <form action="/tournaments/<%= tournament._id %>/applicants/<%= app.player._id %>/accept?_method=PATCH" method="POST">
                            <button class="btn btn-success btn-sm w-100">✓ Accept</button>
                          </form>
                          <form action="/tournaments/<%= tournament._id %>/applicants/<%= app.player._id %>/reject?_method=PATCH" method="POST">
                            <button class="btn btn-danger btn-sm w-100">✗ Reject</button>
                          </form>
                        </div>
                      </div>
                    </div>
                  <% }) %>
                <% } %>

                <% if (accepted.length > 0) { %>
                  <p style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.15em; margin: 12px 0 8px;">
                    ACCEPTED (<%= accepted.length %>)
                  </p>
                  <% accepted.forEach(app => { %>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <div>
                        <a href="/profile/<%= app.player._id %>"
                          style="font-size:0.82rem; font-weight:600; color:#86efac; text-decoration:none;">
                          <%= app.player.username %>
                        </a>
                        <div style="font-size:0.68rem; color:#475569;">
                          <%= app.player.gameUsername || 'No IGN' %>
                        </div>
                      </div>
                      <span class="badge bg-success">ACCEPTED</span>
                    </div>
                  <% }) %>
                <% } %>

                <% if (rejected.length > 0) { %>
                  <p style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.15em; margin: 12px 0 8px;">
                    REJECTED (<%= rejected.length %>)
                  </p>
                  <% rejected.forEach(app => { %>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <div>
                        <a href="/profile/<%= app.player._id %>"
                          style="font-size:0.82rem; color:#475569; text-decoration:none;">
                          <%= app.player.username %>
                        </a>
                      </div>
                      <span class="badge bg-danger">REJECTED</span>
                    </div>
                  <% }) %>
                <% } %>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>

    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>