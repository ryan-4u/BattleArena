<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Create Tournament | BattleArena</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>
    <div class="row justify-content-center">
      <div class="col-md-7">
        <div class="card shadow border-0 ba-card">
          <div class="card-body p-4">
            <h3 class="fw-bold mb-4"><i class="bi bi-trophy text-warning"></i> Create Tournament</h3>
            <form action="/tournaments" method="POST">

              <div class="mb-3">
                <label class="form-label fw-semibold">Tournament Title</label>
                <input type="text" name="tournament[title]" class="form-control" placeholder="e.g. Valorant Pro League S1" required/>
              </div>

              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Game</label>
                  <input type="text" name="tournament[game]" class="form-control" placeholder="e.g. BGMI, Valorant" required/>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Mode</label>
                  <select name="tournament[mode]" class="form-select" required>
                    <option value="Solo">Solo</option>
                    <option value="Duo">Duo</option>
                    <option value="Squad">Squad</option>
                  </select>
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea name="tournament[description]" class="form-control" rows="3" required placeholder="Describe the tournament..."></textarea>
              </div>

              <div class="mb-3">
                <label class="form-label fw-semibold">Rules</label>
                <textarea name="tournament[rules]" class="form-control" rows="3" placeholder="List the rules..."></textarea>
              </div>

              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Prize Pool</label>
                  <input type="text" name="tournament[prizePool]" class="form-control" placeholder="e.g. ₹5000 or No Prize"/>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Entry Fee (₹)</label>
                  <input type="number" name="tournament[entryFee]" class="form-control" value="0" min="0"/>
                </div>
              </div>

              <div class="row g-3 mb-3">
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Max Players</label>
                  <input type="number" name="tournament[maxPlayers]" class="form-control" min="2" required/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Start Date</label>
                  <input type="datetime-local" name="tournament[startDate]" class="form-control" required/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Registration Deadline</label>
                  <input type="datetime-local" name="tournament[registrationDeadline]" class="form-control" required/>
                </div>
              </div>

              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Room ID <span class="text-muted fw-normal">(shown only to accepted players)</span></label>
                  <input type="text" name="tournament[roomId]" class="form-control" placeholder="Set later or now"/>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Room Password</label>
                  <input type="text" name="tournament[roomPassword]" class="form-control" placeholder="Set later or now"/>
                </div>
              </div>

              <div class="mb-4">
                <label class="form-label fw-semibold">Status</label>
                <select name="tournament[status]" class="form-select">
                  <option value="upcoming">Upcoming</option>
                  <option value="ongoing">Ongoing</option>
                  <option value="completed">Completed</option>
                </select>
              </div>

              <button class="btn btn-warning w-100 fw-bold py-2">
                <i class="bi bi-trophy-fill"></i> Create Tournament
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>