<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Create Tournament | BattleArena</title>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>
    <div class="row justify-content-center">
      <div class="col-md-7">
        <div class="card shadow border-0 ba-card">
          <div class="card-body p-4">
            <h3 class="fw-bold mb-4"><i class="bi bi-trophy text-warning"></i> Create Tournament</h3>

            <form action="/tournaments" method="POST" id="tournamentForm" novalidate>

              <!-- Title -->
              <div class="mb-3">
                <label class="form-label fw-semibold">Tournament Title</label>
                <input type="text" name="tournament[title]" class="form-control" id="title"
                  placeholder="e.g. City Chess Open 2025, Valorant Pro League S1" required minlength="3"/>
                <div class="invalid-feedback">Title must be at least 3 characters.</div>
              </div>

              <!-- Sport Category -->
              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Sport / Game Category</label>
                  <select name="tournament[sportCategory]" class="form-select" id="sportCategory" required>
                    <option value="">-- Select Category --</option>
                    <option value="battle-royale">Battle Royale (BGMI, Free Fire, PUBG)</option>
                    <option value="fps-shooter">FPS / Shooter (Valorant, CS2)</option>
                    <option value="chess">Chess</option>
                    <option value="badminton">Badminton</option>
                    <option value="coding">Coding / Hackathon</option>
                    <option value="offline-sport">Offline Sport (Football, Cricket, etc.)</option>
                    <option value="other">Other</option>
                  </select>
                  <div class="invalid-feedback">Please select a category.</div>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">
                    Game / Sport Name
                    <span class="text-muted fw-normal" style="font-size:0.75rem; font-family:'DM Sans'; text-transform:none; letter-spacing:0;">
                      (specific name)
                    </span>
                  </label>
                  <input type="text" name="tournament[game]" class="form-control" id="game"
                    placeholder="e.g. Chess, BGMI, Badminton, LeetCode" required/>
                  <div class="invalid-feedback">Please enter the game or sport name.</div>
                </div>
              </div>

              <!-- Format / Mode -->
              <div class="mb-3">
                <label class="form-label fw-semibold">
                  Participation Format
                  <span class="text-muted fw-normal" style="font-size:0.75rem; font-family:'DM Sans'; text-transform:none; letter-spacing:0;">
                    (select category first)
                  </span>
                </label>
                <select name="tournament[mode]" class="form-select" id="mode" required>
                  <option value="">-- Select Category First --</option>
                </select>
                <div class="invalid-feedback">Please select a participation format.</div>
              </div>

              <!-- Description -->
              <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea name="tournament[description]" class="form-control" id="description"
                  rows="3" required minlength="10"
                  placeholder="Describe the tournament format, who can join, what to expect..."></textarea>
                <div class="invalid-feedback">Description must be at least 10 characters.</div>
              </div>

              <!-- Rules -->
              <div class="mb-3">
                <label class="form-label fw-semibold">Rules</label>
                <div id="rulesContainer">
                  <div class="rule-item d-flex gap-2 mb-2">
                    <span class="rule-number cyber-tag-line pt-2">01.</span>
                    <input type="text" class="form-control rule-input"
                      placeholder="e.g. No cheating or unsportsmanlike conduct"/>
                    <button type="button" class="btn btn-outline-danger btn-sm remove-rule" style="display:none;">
                      <i class="bi bi-x"></i>
                    </button>
                  </div>
                </div>
                <input type="hidden" name="tournament[rules]" id="rulesHidden"/>
                <button type="button" class="btn btn-outline-warning btn-sm mt-1" id="addRuleBtn">
                  <i class="bi bi-plus"></i> Add Rule
                </button>
                <div class="text-danger small mt-1" id="rulesError" style="display:none;"></div>
              </div>

              <!-- Prize + Entry Fee -->
              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Prize Pool</label>
                  <input type="text" name="tournament[prizePool]" class="form-control"
                    placeholder="e.g. ₹5000 Cash, Trophy, No Prize"/>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Entry Fee (₹)</label>
                  <input type="number" name="tournament[entryFee]" class="form-control"
                    id="entryFee" value="0" min="0"/>
                  <div class="invalid-feedback">Entry fee cannot be negative.</div>
                </div>
              </div>

              <!-- Max Players + Dates -->
              <div class="row g-3 mb-3">
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Max Participants</label>
                  <input type="number" name="tournament[maxPlayers]" class="form-control"
                    id="maxPlayers" min="2" max="500" required
                    placeholder="e.g. 16, 32, 64"/>
                  <div class="invalid-feedback">Min 2, max 500 participants.</div>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Start Date & Time</label>
                  <input type="datetime-local" name="tournament[startDate]"
                    class="form-control" id="startDate" required/>
                  <div class="invalid-feedback">Start date must be in the future.</div>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Registration Closes</label>
                  <input type="datetime-local" name="tournament[registrationDeadline]"
                    class="form-control" id="regDeadline" required/>
                  <div class="invalid-feedback">Deadline must be before the start date.</div>
                </div>
              </div>

              <!-- Status -->
              <div class="mb-4">
                <label class="form-label fw-semibold">Initial Status</label>
                <select name="tournament[status]" class="form-select">
                  <option value="upcoming">Upcoming — Open for registration</option>
                  <option value="ongoing">Ongoing — Currently in progress</option>
                  <option value="completed">Completed — Tournament finished</option>
                </select>
              </div>

              <!-- Tournament Format -->
              <div class="mb-4">
                <label class="form-label fw-semibold">Tournament Format</label>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="d-block" style="cursor:pointer;">
                      <input type="radio" name="tournament[tournamentFormat]" value="simple" class="d-none format-radio" id="formatSimple"/>
                      <div class="format-card p-3" id="formatSimpleCard" style="border:1px solid rgba(56,189,248,0.2); border-radius:4px; transition:all 0.2s;">
                        <div class="d-flex align-items-center gap-2 mb-1">
                          <div class="format-dot" style="width:10px; height:10px; border-radius:50%; border:2px solid #38bdf8;"></div>
                          <span class="fw-semibold" style="font-size:0.9rem;">Simple Match</span>
                        </div>
                        <p style="font-size:0.75rem; color:#475569; margin:0; font-family:'DM Sans';">
                          Single match or session. Organiser declares the winner directly. Best for: Battle Royale lobbies, single chess games, one-round events.
                        </p>
                      </div>
                    </label>
                  </div>
                  <div class="col-md-6">
                    <label class="d-block" style="cursor:pointer;">
                      <input type="radio" name="tournament[tournamentFormat]" value="bracket" class="d-none format-radio" id="formatBracket" checked/>
                      <div class="format-card p-3" id="formatBracketCard" style="border:1px solid rgba(250,204,21,0.5); background:rgba(250,204,21,0.04); border-radius:4px; transition:all 0.2s;">
                        <div class="d-flex align-items-center gap-2 mb-1">
                          <div class="format-dot" style="width:10px; height:10px; border-radius:50%; background:#facc15; border:2px solid #facc15;"></div>
                          <span class="fw-semibold" style="font-size:0.9rem;">Bracket Tournament</span>
                        </div>
                        <p style="font-size:0.75rem; color:#475569; margin:0; font-family:'DM Sans';">
                          Multi-round elimination bracket. Players progress round by round. Best for: large tournaments, offline sports, chess championships, coding contests.
                        </p>
                      </div>
                    </label>
                  </div>
                </div>
              </div>

              <button type="submit" class="btn btn-warning w-100 fw-bold py-2">
                <i class="bi bi-trophy-fill"></i> Create Tournament
              </button>

            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/js/tournament-form.js"></script>
  <script>
    // Format card toggle
    document.querySelectorAll('.format-radio').forEach(radio => {
      radio.addEventListener('change', () => {
        document.querySelectorAll('.format-card').forEach(card => {
          card.style.border = '1px solid rgba(56,189,248,0.2)';
          card.style.background = 'transparent';
          card.querySelector('.format-dot').style.background = 'transparent';
        });
        const selectedCard = radio.nextElementSibling;
        selectedCard.style.border = '1px solid rgba(250,204,21,0.5)';
        selectedCard.style.background = 'rgba(250,204,21,0.04)';
        selectedCard.querySelector('.format-dot').style.background = '#facc15';
      });
    });
  </script>
</body>
</html>