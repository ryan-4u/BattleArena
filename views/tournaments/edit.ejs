<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Edit Tournament | BattleArena</title>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>
    <div class="row justify-content-center">
      <div class="col-md-7">
        <div class="card shadow border-0 ba-card">
          <div class="card-body p-4">
            <h3 class="fw-bold mb-4"><i class="bi bi-pencil-square text-warning"></i> Edit Tournament</h3>

            <form action="/tournaments/<%= tournament._id %>?_method=PUT" method="POST"
              id="editForm" novalidate>

              <div class="mb-3">
                <label class="form-label fw-semibold">Tournament Title</label>
                <input type="text" name="tournament[title]" class="form-control" id="title"
                  value="<%= tournament.title %>" required minlength="3"/>
                <div class="invalid-feedback">Title must be at least 3 characters.</div>
              </div>

              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Game</label>
                  <input type="text" name="tournament[game]" class="form-control" id="game"
                    value="<%= tournament.game %>" required/>
                  <div class="invalid-feedback">Please enter the game name.</div>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Mode</label>
                  <select name="tournament[mode]" class="form-select" id="mode" required>
                    <option value="">-- Select Mode --</option>
                    <option value="Solo"  <%= tournament.mode === 'Solo'  ? 'selected' : '' %>>Solo</option>
                    <option value="Duo"   <%= tournament.mode === 'Duo'   ? 'selected' : '' %>>Duo</option>
                    <option value="Squad" <%= tournament.mode === 'Squad' ? 'selected' : '' %>>Squad</option>
                  </select>
                  <div class="invalid-feedback">Please select a mode.</div>
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea name="tournament[description]" class="form-control" id="description"
                  rows="3" required minlength="10"><%= tournament.description %></textarea>
                <div class="invalid-feedback">Description must be at least 10 characters.</div>
              </div>

              <div class="mb-3">
                <label class="form-label fw-semibold">Rules</label>
                <div id="rulesContainer">
                  <%
                    const existingRules = tournament.rules
                      ? tournament.rules.split('\n').filter(r => r.trim()).map(r => r.replace(/^\d+\.\s*/, ''))
                      : [''];
                  %>
                  <% existingRules.forEach((rule, idx) => { %>
                    <div class="rule-item d-flex gap-2 mb-2">
                      <span class="rule-number cyber-tag-line pt-2">
                        <%= String(idx + 1).padStart(2, '0') %>.
                      </span>
                      <input type="text" class="form-control rule-input"
                        placeholder="Add a rule..." value="<%= rule %>"/>
                      <button type="button" class="btn btn-outline-danger btn-sm remove-rule"
                        style="<%= existingRules.length <= 1 ? 'display:none' : '' %>">
                        <i class="bi bi-x"></i>
                      </button>
                    </div>
                  <% }) %>
                </div>
                <input type="hidden" name="tournament[rules]" id="rulesHidden"/>
                <button type="button" class="btn btn-outline-warning btn-sm mt-1" id="addRuleBtn">
                  <i class="bi bi-plus"></i> Add Rule
                </button>
                <div class="text-danger small mt-1" id="rulesError" style="display:none;"></div>
              </div>

              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Prize Pool</label>
                  <input type="text" name="tournament[prizePool]" class="form-control"
                    value="<%= tournament.prizePool %>"/>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Entry Fee (₹)</label>
                  <input type="number" name="tournament[entryFee]" class="form-control"
                    id="entryFee" value="<%= tournament.entryFee %>" min="0"/>
                  <div class="invalid-feedback">Entry fee cannot be negative.</div>
                </div>
              </div>

              <div class="row g-3 mb-3">
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Max Players</label>
                  <input type="number" name="tournament[maxPlayers]" class="form-control"
                    id="maxPlayers" value="<%= tournament.maxPlayers %>" min="2" max="500"/>
                  <div class="invalid-feedback">Min 2, max 500 players.</div>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Start Date</label>
                  <input type="datetime-local" name="tournament[startDate]"
                    class="form-control" id="startDate"
                    value="<%= new Date(tournament.startDate).toISOString().slice(0,16) %>"/>
                  <div class="invalid-feedback">Please set a valid start date.</div>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Registration Deadline</label>
                  <input type="datetime-local" name="tournament[registrationDeadline]"
                    class="form-control" id="regDeadline"
                    value="<%= new Date(tournament.registrationDeadline).toISOString().slice(0,16) %>"/>
                  <div class="invalid-feedback">Deadline must be before start date.</div>
                </div>
              </div>

              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">
                    Room ID
                    <span class="text-muted fw-normal"
                      style="font-family:'DM Sans'; font-size:0.75rem; text-transform:none; letter-spacing:0;">
                      (visible only to accepted players)
                    </span>
                  </label>
                  <input type="text" name="tournament[roomId]" class="form-control"
                    value="<%= tournament.roomId %>"/>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Room Password</label>
                  <input type="text" name="tournament[roomPassword]" class="form-control"
                    value="<%= tournament.roomPassword %>"/>
                </div>
              </div>

              <div class="mb-4">
                <label class="form-label fw-semibold">Status</label>
                <select name="tournament[status]" class="form-select">
                  <option value="upcoming"  <%= tournament.status === 'upcoming'  ? 'selected' : '' %>>Upcoming</option>
                  <option value="ongoing"   <%= tournament.status === 'ongoing'   ? 'selected' : '' %>>Ongoing</option>
                  <option value="completed" <%= tournament.status === 'completed' ? 'selected' : '' %>>Completed</option>
                </select>
              </div>

              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning fw-bold px-4">
                  <i class="bi bi-save"></i> Save Changes
                </button>
                <a href="/tournaments/<%= tournament._id %>" class="btn btn-outline-secondary">Cancel</a>
              </div>

            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/js/tournament-form.js"></script>
</body>
</html>