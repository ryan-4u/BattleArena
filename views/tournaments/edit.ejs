<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Edit Tournament | BattleArena</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>
    <div class="row justify-content-center">
      <div class="col-md-7">
        <div class="card shadow border-0 ba-card">
          <div class="card-body p-4">
            <h3 class="fw-bold mb-4"><i class="bi bi-pencil-square text-warning"></i> Edit Tournament</h3>
            <form action="/tournaments/<%= tournament._id %>?_method=PUT" method="POST">

              <div class="mb-3">
                <label class="form-label fw-semibold">Title</label>
                <input type="text" name="tournament[title]" class="form-control" value="<%= tournament.title %>" required/>
              </div>

              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Game</label>
                  <input type="text" name="tournament[game]" class="form-control" value="<%= tournament.game %>" required/>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Mode</label>
                  <select name="tournament[mode]" class="form-select">
                    <option value="Solo" <%= tournament.mode === 'Solo' ? 'selected' : '' %>>Solo</option>
                    <option value="Duo" <%= tournament.mode === 'Duo' ? 'selected' : '' %>>Duo</option>
                    <option value="Squad" <%= tournament.mode === 'Squad' ? 'selected' : '' %>>Squad</option>
                  </select>
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea name="tournament[description]" class="form-control" rows="3" required><%= tournament.description %></textarea>
              </div>

              <div class="mb-3">
                <label class="form-label fw-semibold">Rules</label>
                <textarea name="tournament[rules]" class="form-control" rows="3"><%= tournament.rules %></textarea>
              </div>

              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Prize Pool</label>
                  <input type="text" name="tournament[prizePool]" class="form-control" value="<%= tournament.prizePool %>"/>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Entry Fee (₹)</label>
                  <input type="number" name="tournament[entryFee]" class="form-control" value="<%= tournament.entryFee %>" min="0"/>
                </div>
              </div>

              <div class="row g-3 mb-3">
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Max Players</label>
                  <input type="number" name="tournament[maxPlayers]" class="form-control" value="<%= tournament.maxPlayers %>" min="2"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Start Date</label>
                  <input type="datetime-local" name="tournament[startDate]" class="form-control"
                    value="<%= new Date(tournament.startDate).toISOString().slice(0,16) %>"/>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Registration Deadline</label>
                  <input type="datetime-local" name="tournament[registrationDeadline]" class="form-control"
                    value="<%= new Date(tournament.registrationDeadline).toISOString().slice(0,16) %>"/>
                </div>
              </div>

              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Room ID</label>
                  <input type="text" name="tournament[roomId]" class="form-control" value="<%= tournament.roomId %>"/>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Room Password</label>
                  <input type="text" name="tournament[roomPassword]" class="form-control" value="<%= tournament.roomPassword %>"/>
                </div>
              </div>

              <div class="mb-4">
                <label class="form-label fw-semibold">Status</label>
                <select name="tournament[status]" class="form-select">
                  <option value="upcoming" <%= tournament.status === 'upcoming' ? 'selected' : '' %>>Upcoming</option>
                  <option value="ongoing" <%= tournament.status === 'ongoing' ? 'selected' : '' %>>Ongoing</option>
                  <option value="completed" <%= tournament.status === 'completed' ? 'selected' : '' %>>Completed</option>
                </select>
              </div>

              <div class="d-flex gap-2">
                <button class="btn btn-warning fw-bold px-4">
                  <i class="bi bi-save"></i> Save Changes
                </button>
                <a href="/tournaments/<%= tournament._id %>" class="btn btn-outline-secondary">Cancel</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>