<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Edit Tournament | BattleArena</title>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>
    <div class="row justify-content-center">
      <div class="col-md-7">
        <div class="card shadow border-0 ba-card">
          <div class="card-body p-4">
            <h3 class="fw-bold mb-4"><i class="bi bi-pencil-square text-warning"></i> Edit Tournament</h3>

            <form action="/tournaments/<%= tournament._id %>?_method=PUT" method="POST" id="editForm" novalidate>

              <!-- Title -->
              <div class="mb-3">
                <label class="form-label fw-semibold">Tournament Title</label>
                <input type="text" name="tournament[title]" class="form-control"
                  value="<%= tournament.title %>" required minlength="3"/>
                <div class="invalid-feedback">Title must be at least 3 characters.</div>
              </div>

              <!-- Sport Category + Game Name -->
              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Sport / Game Category</label>
                  <select name="tournament[sportCategory]" class="form-select" id="sportCategory" required>
                    <option value="">-- Select Category --</option>
                    <option value="battle-royale" <%= tournament.sportCategory === 'battle-royale' ? 'selected' : '' %>>Battle Royale (BGMI, Free Fire, PUBG)</option>
                    <option value="fps-shooter"   <%= tournament.sportCategory === 'fps-shooter'   ? 'selected' : '' %>>FPS / Shooter (Valorant, CS2)</option>
                    <option value="chess"          <%= tournament.sportCategory === 'chess'          ? 'selected' : '' %>>Chess</option>
                    <option value="badminton"      <%= tournament.sportCategory === 'badminton'      ? 'selected' : '' %>>Badminton</option>
                    <option value="coding"         <%= tournament.sportCategory === 'coding'         ? 'selected' : '' %>>Coding / Hackathon</option>
                    <option value="offline-sport"  <%= tournament.sportCategory === 'offline-sport'  ? 'selected' : '' %>>Offline Sport (Football, Cricket, etc.)</option>
                    <option value="other"          <%= tournament.sportCategory === 'other'          ? 'selected' : '' %>>Other</option>
                  </select>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Game / Sport Name</label>
                  <input type="text" name="tournament[game]" class="form-control"
                    value="<%= tournament.game %>" required/>
                  <div class="invalid-feedback">Please enter the game or sport name.</div>
                </div>
              </div>

              <!-- Format / Mode — data-current-mode lets JS pre-select the right option -->
              <div class="mb-3">
                <label class="form-label fw-semibold">Participation Format</label>
                <select name="tournament[mode]" class="form-select" id="mode"
                  data-current-mode="<%= tournament.mode %>" required>
                  <option value="">-- Select Format --</option>
                </select>
                <div class="invalid-feedback">Please select a format.</div>
              </div>

              <!-- Description -->
              <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea name="tournament[description]" class="form-control"
                  rows="3" required minlength="10"><%= tournament.description %></textarea>
                <div class="invalid-feedback">Description must be at least 10 characters.</div>
              </div>

              <!-- Rules -->
              <div class="mb-3">
                <label class="form-label fw-semibold">Rules</label>
                <div id="rulesContainer">
                  <%
                    const existingRules = tournament.rules
                      ? tournament.rules.split('\n').filter(r => r.trim()).map(r => r.replace(/^\d+\.\s*/, ''))
                      : [''];
                  %>
                  <% existingRules.forEach((rule, idx) => { %>
                    <div class="rule-item d-flex gap-2 mb-2">
                      <span class="rule-number cyber-tag-line pt-2"><%= String(idx + 1).padStart(2, '0') %>.</span>
                      <input type="text" class="form-control rule-input"
                        placeholder="Add a rule..." value="<%= rule %>"/>
                      <button type="button" class="btn btn-outline-danger btn-sm remove-rule"
                        style="<%= existingRules.length <= 1 ? 'display:none' : '' %>">
                        <i class="bi bi-x"></i>
                      </button>
                    </div>
                  <% }) %>
                </div>
                <input type="hidden" name="tournament[rules]" id="rulesHidden"/>
                <button type="button" class="btn btn-outline-warning btn-sm mt-1" id="addRuleBtn">
                  <i class="bi bi-plus"></i> Add Rule
                </button>
                <div class="text-danger small mt-1" id="rulesError" style="display:none;"></div>
              </div>

              <!-- Prize + Entry Fee -->
              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Prize Pool</label>
                  <input type="text" name="tournament[prizePool]" class="form-control"
                    value="<%= tournament.prizePool %>"/>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Entry Fee (₹)</label>
                  <input type="number" name="tournament[entryFee]" class="form-control"
                    id="entryFee" value="<%= tournament.entryFee %>" min="0"/>
                  <div class="invalid-feedback">Entry fee cannot be negative.</div>
                </div>
              </div>

              <!-- Max Players + Dates -->
              <div class="row g-3 mb-3">
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Max Participants</label>
                  <input type="number" name="tournament[maxPlayers]" class="form-control"
                    id="maxPlayers" value="<%= tournament.maxPlayers %>" min="2" max="500"/>
                  <div class="invalid-feedback">Min 2, max 500 participants.</div>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Start Date & Time</label>
                  <input type="datetime-local" name="tournament[startDate]"
                    class="form-control"
                    value="<%= new Date(tournament.startDate).toISOString().slice(0,16) %>"/>
                  <div class="invalid-feedback">Please set a valid start date.</div>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Registration Closes</label>
                  <input type="datetime-local" name="tournament[registrationDeadline]"
                    class="form-control"
                    value="<%= new Date(tournament.registrationDeadline).toISOString().slice(0,16) %>"/>
                  <div class="invalid-feedback">Deadline must be before start date.</div>
                </div>
              </div>

              <!-- Status -->
              <div class="mb-4">
                <label class="form-label fw-semibold">Status</label>
                <select name="tournament[status]" class="form-select">
                  <option value="upcoming"  <%= tournament.status === 'upcoming'  ? 'selected' : '' %>>Upcoming — Open for registration</option>
                  <option value="ongoing"   <%= tournament.status === 'ongoing'   ? 'selected' : '' %>>Ongoing — Currently in progress</option>
                  <option value="completed" <%= tournament.status === 'completed' ? 'selected' : '' %>>Completed — Tournament finished</option>
                </select>
              </div>

              <!-- Tournament Format -->
              <div class="mb-4">
                <label class="form-label fw-semibold">Tournament Format</label>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="d-block" style="cursor:pointer;">
                      <input type="radio" name="tournament[tournamentFormat]" value="simple"
                        class="d-none format-radio" id="formatSimple"
                        <%= tournament.tournamentFormat === 'simple' ? 'checked' : '' %>/>
                      <div class="format-card p-3" id="formatSimpleCard"
                        style="border:1px solid <%= tournament.tournamentFormat === 'simple' ? 'rgba(250,204,21,0.5)' : 'rgba(56,189,248,0.2)' %>; background:<%= tournament.tournamentFormat === 'simple' ? 'rgba(250,204,21,0.04)' : 'transparent' %>; border-radius:4px; transition:all 0.2s;">
                        <div class="d-flex align-items-center gap-2 mb-1">
                          <div class="format-dot" style="width:10px; height:10px; border-radius:50%; background:<%= tournament.tournamentFormat === 'simple' ? '#facc15' : 'transparent' %>; border:2px solid #facc15;"></div>
                          <span class="fw-semibold" style="font-size:0.9rem;">Simple Match</span>
                        </div>
                        <p style="font-size:0.75rem; color:#475569; margin:0; font-family:'DM Sans';">
                          Single match or session. Organiser declares the winner directly. Best for: Battle Royale lobbies, single chess games, one-round events.
                        </p>
                      </div>
                    </label>
                  </div>
                  <div class="col-md-6">
                    <label class="d-block" style="cursor:pointer;">
                      <input type="radio" name="tournament[tournamentFormat]" value="bracket"
                        class="d-none format-radio" id="formatBracket"
                        <%= (!tournament.tournamentFormat || tournament.tournamentFormat === 'bracket') ? 'checked' : '' %>/>
                      <div class="format-card p-3" id="formatBracketCard"
                        style="border:1px solid <%= (!tournament.tournamentFormat || tournament.tournamentFormat === 'bracket') ? 'rgba(250,204,21,0.5)' : 'rgba(56,189,248,0.2)' %>; background:<%= (!tournament.tournamentFormat || tournament.tournamentFormat === 'bracket') ? 'rgba(250,204,21,0.04)' : 'transparent' %>; border-radius:4px; transition:all 0.2s;">
                        <div class="d-flex align-items-center gap-2 mb-1">
                          <div class="format-dot" style="width:10px; height:10px; border-radius:50%; background:<%= (!tournament.tournamentFormat || tournament.tournamentFormat === 'bracket') ? '#facc15' : 'transparent' %>; border:2px solid #facc15;"></div>
                          <span class="fw-semibold" style="font-size:0.9rem;">Bracket Tournament</span>
                        </div>
                        <p style="font-size:0.75rem; color:#475569; margin:0; font-family:'DM Sans';">
                          Multi-round elimination bracket. Players progress round by round. Best for: large tournaments, offline sports, chess championships, coding contests.
                        </p>
                      </div>
                    </label>
                  </div>
                </div>
                <% if (tournament.bracketGenerated) { %>
                  <p style="font-size:0.75rem; color:#f97316; margin-top:8px;">
                    <i class="bi bi-exclamation-triangle"></i> Bracket already generated — format cannot be changed.
                  </p>
                <% } %>
              </div>

              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning fw-bold px-4">
                  <i class="bi bi-save"></i> Save Changes
                </button>
                <a href="/tournaments/<%= tournament._id %>" class="btn btn-outline-secondary">Cancel</a>
              </div>

            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/js/tournament-form.js"></script>
  <script>
    // Format card toggle
    document.querySelectorAll('.format-radio').forEach(radio => {
      radio.addEventListener('change', () => {
        document.querySelectorAll('.format-card').forEach(card => {
          card.style.border = '1px solid rgba(56,189,248,0.2)';
          card.style.background = 'transparent';
          card.querySelector('.format-dot').style.background = 'transparent';
        });
        const selectedCard = radio.nextElementSibling;
        selectedCard.style.border = '1px solid rgba(250,204,21,0.5)';
        selectedCard.style.background = 'rgba(250,204,21,0.04)';
        selectedCard.querySelector('.format-dot').style.background = '#facc15';
      });
    });
  </script>
</body>
</html>