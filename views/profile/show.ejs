<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title><%= profileUser.username %> | BattleArena</title>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>
    <div class="row g-4">

      <!-- Profile Card -->
      <div class="col-md-4">
        <div class="card shadow border-0 ba-card text-center p-4">
          <div class="ba-avatar mx-auto mb-3">
            <%= profileUser.username.charAt(0).toUpperCase() %>
          </div>
          <h4 class="fw-bold"><%= profileUser.username %></h4>
          <span class="badge bg-warning text-dark mb-2"><%= profileUser.role %></span>
          <% if (profileUser.gameUsername) { %>
            <p class="text-muted small"><i class="bi bi-controller"></i> <%= profileUser.gameUsername %></p>
          <% } %>
          <% if (profileUser.bio) { %>
            <p class="small"><%= profileUser.bio %></p>
          <% } %>
          <% if (profileUser.tournamentsWon && profileUser.tournamentsWon.length > 0) { %>
            <div class="mt-2">
              <span style="font-family:'Share Tech Mono',monospace; font-size:0.65rem; color:#facc15; letter-spacing:0.15em;">
                🏆 <%= profileUser.tournamentsWon.length %> TOURNAMENT<%= profileUser.tournamentsWon.length !== 1 ? 'S' : '' %> WON
              </span>
            </div>
          <% } %>

          <!-- Report count — visible to everyone -->
          <% if (profileUser.profileReports && profileUser.profileReports.length > 0) { %>
            <div class="mt-2">
              <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#ef4444; letter-spacing:0.1em;">
                ⚑ <%= profileUser.profileReports.length %> REPORT<%= profileUser.profileReports.length !== 1 ? 'S' : '' %>
              </span>
            </div>
          <% } %>

          <% if (isOwn) { %>
            <a href="/profile/edit" class="btn btn-outline-warning btn-sm mt-2">
              <i class="bi bi-pencil"></i> Edit Profile
            </a>
          <% } else if (currUser) { %>
            <%
              const alreadyReportedProfile = profileUser.profileReports &&
                profileUser.profileReports.some(r => r.reportedBy &&
                  r.reportedBy.toString() === currUser._id.toString());
            %>
            <% if (alreadyReportedProfile) { %>
              <div class="mt-2">
                <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#475569; letter-spacing:0.1em;">
                  You have reported this profile.
                </span>
              </div>
            <% } else { %>
              <button class="btn btn-outline-danger btn-sm mt-2" data-bs-toggle="modal" data-bs-target="#reportProfileModal">
                <i class="bi bi-flag"></i> Report Profile
              </button>
            <% } %>
          <% } %>
        </div>
      </div>

      <!-- Tournaments -->
      <div class="col-md-8">
        <% if (profileUser.role === 'player') { %>

          <!-- Wins section -->
          <% if (profileUser.tournamentsWon && profileUser.tournamentsWon.length > 0) { %>
            <h5 class="fw-bold mb-3">
              <i class="bi bi-trophy-fill" style="color:#facc15;"></i> Tournament Wins
            </h5>
            <div class="list-group mb-4">
              <% for (let t of profileUser.tournamentsWon) { %>
                <a href="/tournaments/<%= t._id %>" class="list-group-item list-group-item-action ba-list-item"
                  style="border-left:3px solid #facc15;">
                  <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-semibold" style="color:#facc15;">🏆 <%= t.title %></span>
                    <span class="badge bg-secondary"><%= t.status %></span>
                  </div>
                  <small class="text-muted"><%= t.game %> | <%= t.mode %></small>
                </a>
              <% } %>
            </div>
          <% } %>

          <!-- Tournaments Joined -->
          <h5 class="fw-bold mb-3">
            <i class="bi bi-trophy text-warning"></i> Tournaments Joined
          </h5>
          <% if (profileUser.tournamentsJoined.length === 0) { %>
            <p class="text-muted">No tournaments joined yet.</p>
          <% } else { %>
            <div class="list-group">
              <% for (let t of profileUser.tournamentsJoined) { %>
                <a href="/tournaments/<%= t._id %>" class="list-group-item list-group-item-action ba-list-item">
                  <div class="d-flex justify-content-between">
                    <span class="fw-semibold"><%= t.title %></span>
                    <span class="badge
                      <%= t.status === 'upcoming' ? 'bg-success' : t.status === 'ongoing' ? 'bg-warning text-dark' : 'bg-secondary' %>">
                      <%= t.status %>
                    </span>
                  </div>
                  <small class="text-muted"><%= t.game %> | <%= t.mode %></small>
                </a>
              <% } %>
            </div>
          <% } %>

        <% } else { %>

          <!-- Tournaments Organised -->
          <h5 class="fw-bold mb-3">
            <i class="bi bi-trophy text-warning"></i> Tournaments Organised
          </h5>
          <% if (profileUser.tournamentsOrganised.length === 0) { %>
            <p class="text-muted">No tournaments organised yet.</p>
          <% } else { %>
            <div class="list-group">
              <% for (let t of profileUser.tournamentsOrganised) { %>
                <a href="/tournaments/<%= t._id %>" class="list-group-item list-group-item-action ba-list-item">
                  <div class="d-flex justify-content-between">
                    <span class="fw-semibold"><%= t.title %></span>
                    <span class="badge
                      <%= t.status === 'upcoming' ? 'bg-success' : t.status === 'ongoing' ? 'bg-warning text-dark' : 'bg-secondary' %>">
                      <%= t.status %>
                    </span>
                  </div>
                  <small class="text-muted"><%= t.game %> | <%= t.mode %></small>
                </a>
              <% } %>
            </div>
          <% } %>

        <% } %>
      </div>

    </div>
  </div>

  <!-- Report Profile Modal -->
  <div class="modal fade" id="reportProfileModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content" style="background:#0a0f1e; border:1px solid rgba(239,68,68,0.3); border-radius:0;">
        <div class="modal-header" style="border-bottom:1px solid rgba(239,68,68,0.15);">
          <h6 class="modal-title fw-bold" style="font-family:'Orbitron',monospace; font-size:0.85rem; color:#ef4444;">
            REPORT PROFILE
          </h6>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <form action="/profile/<%= profileUser._id %>/report" method="POST">
          <div class="modal-body">
            <p style="font-size:0.82rem; color:#94a3b8; margin-bottom:14px;">
              Tell us why you are reporting <strong style="color:var(--cyber-blue);"><%= profileUser.username %></strong>.
            </p>
            <label class="form-label fw-semibold" style="font-size:0.78rem;">Reason</label>
            <textarea name="reason" class="form-control" rows="3"
              placeholder="e.g. Fake account, harassment, cheating..."></textarea>
          </div>
          <div class="modal-footer" style="border-top:1px solid rgba(239,68,68,0.15);">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-danger btn-sm">Submit Report</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%- include('../partials/scripts') %>
</body>
</html>