<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title><%= profileUser.username %> | BattleArena</title>
</head>
<body class="ba-bg">
  <%- include('../partials/navbar') %>
  <div class="container my-5">
    <%- include('../partials/flash') %>
    <div class="row g-4">
      <!-- Profile Card -->
      <div class="col-md-4">
        <div class="card shadow border-0 ba-card text-center p-4">
          <div class="ba-avatar mx-auto mb-3">
            <%= profileUser.username.charAt(0).toUpperCase() %>
          </div>
          <h4 class="fw-bold"><%= profileUser.username %></h4>
          <span class="badge bg-warning text-dark mb-2"><%= profileUser.role %></span>
          <% if (profileUser.gameUsername) { %>
            <p class="text-muted small"><i class="bi bi-controller"></i> <%= profileUser.gameUsername %></p>
          <% } %>
          <% if (profileUser.bio) { %>
            <p class="small"><%= profileUser.bio %></p>
          <% } %>
          <% if (isOwn) { %>
            <a href="/profile/edit" class="btn btn-outline-warning btn-sm mt-2">
              <i class="bi bi-pencil"></i> Edit Profile
            </a>
          <% } %>
        </div>
      </div>

      <!-- Tournaments -->
      <div class="col-md-8">
        <% if (profileUser.role === 'player') { %>
          <h5 class="fw-bold mb-3"><i class="bi bi-trophy text-warning"></i> Tournaments Joined</h5>
          <% if (profileUser.tournamentsJoined.length === 0) { %>
            <p class="text-muted">No tournaments joined yet.</p>
          <% } else { %>
            <div class="list-group">
              <% for (let t of profileUser.tournamentsJoined) { %>
                <a href="/tournaments/<%= t._id %>" class="list-group-item list-group-item-action ba-list-item">
                  <div class="d-flex justify-content-between">
                    <span class="fw-semibold"><%= t.title %></span>
                    <span class="badge
                      <%= t.status === 'upcoming' ? 'bg-success' : t.status === 'ongoing' ? 'bg-warning text-dark' : 'bg-secondary' %>">
                      <%= t.status %>
                    </span>
                  </div>
                  <small class="text-muted"><%= t.game %> | <%= t.mode %></small>
                </a>
              <% } %>
            </div>
          <% } %>
        <% } else { %>
          <h5 class="fw-bold mb-3"><i class="bi bi-trophy text-warning"></i> Tournaments Organised</h5>
          <% if (profileUser.tournamentsOrganised.length === 0) { %>
            <p class="text-muted">No tournaments organised yet.</p>
          <% } else { %>
            <div class="list-group">
              <% for (let t of profileUser.tournamentsOrganised) { %>
                <a href="/tournaments/<%= t._id %>" class="list-group-item list-group-item-action ba-list-item">
                  <div class="d-flex justify-content-between">
                    <span class="fw-semibold"><%= t.title %></span>
                    <span class="badge
                      <%= t.status === 'upcoming' ? 'bg-success' : t.status === 'ongoing' ? 'bg-warning text-dark' : 'bg-secondary' %>">
                      <%= t.status %>
                    </span>
                  </div>
                  <small class="text-muted"><%= t.game %> | <%= t.mode %></small>
                </a>
              <% } %>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>
  <%- include('../partials/scripts') %>
</body>
</html>