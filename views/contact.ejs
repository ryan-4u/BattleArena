<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact - Battle Arena</title>
    <link rel="stylesheet" href="/css/style.css">
    <!-- Keep existing contact styles in style.css or add here -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
</head>
<body>
    <%- include("./includes/navbar.ejs") %>

    <!-- Hero Section -->
<section class="hero bg-primary text-white py-5" style="background-color: #e7f0fa;">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <h1 class="display-4 fw-bold" style="color: #2e5e99;">Get in Touch</h1>
        <p class="lead" style="color: #0d2440;">Have questions about hosting esports tournaments or joining as a player? We're here to help. Reach out to our team for support, partnerships, or feedback.</p>
      </div>
      <div class="col-lg-6 text-center">
        <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Esports team collaborating" class="img-fluid rounded shadow" style="max-height: 400px;">
      </div>
    </div>
  </div>
</section>

<!-- Contact Form and Details Section -->
<section class="py-5 bg-light" style="background-color: #e7f0fa;">
  <div class="container">
    <div class="row g-5">
      <!-- Contact Form -->
      <div class="col-lg-8">
        <h2 class="mb-4 fw-bold" style="color: #2e5e99;">Send Us a Message</h2>
        <form id="contactForm">
          <div class="mb-3">
            <label for="name" class="form-label" style="color: #0d2440;">Full Name</label>
            <input type="text" class="form-control" id="name" placeholder="Enter your name" required>
          </div>
          <div class="mb-3">
            <label for="email" class="form-label" style="color: #0d2440;">Email Address</label>
            <input type="email" class="form-control" id="email" placeholder="Enter your email" required>
          </div>
          <div class="mb-3">
            <label for="subject" class="form-label" style="color: #0d2440;">Subject</label>
            <select class="form-select" id="subject" required>
              <option value="">Choose a topic</option>
              <option value="tournament-support">Tournament Hosting Support</option>
              <option value="player-help">Player Assistance</option>
              <option value="partnerships">Partnerships & Sponsorships</option>
              <option value="feedback">Feedback & Suggestions</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="mb-3">
            <label for="message" class="form-label" style="color: #0d2440;">Message</label>
            <textarea class="form-control" id="message" rows="5" placeholder="Tell us how we can help..." required></textarea>
          </div>
          <button type="submit" class="btn btn-lg" style="background-color: #7ba4d0; color: white; border: none;">Send Message</button>
        </form>
      </div>
      
      <!-- Contact Details -->
      <div class="col-lg-4">
        <h3 class="mb-4 fw-bold" style="color: #2e5e99;">Contact Information</h3>
        <div class="contact-info">
          <div class="mb-3">
            <i class="bi bi-envelope-fill me-2" style="color: #7ba4d0;"></i>
            <strong>Email:</strong> <a href="mailto:support@esportstournaments.com" style="color: #0d2440; text-decoration: none;">support@esportstournaments.com</a>
          </div>
          <div class="mb-3">
            <i class="bi bi-telephone-fill me-2" style="color: #7ba4d0;"></i>
            <strong>Phone:</strong> <a href="tel:+1234567890" style="color: #0d2440; text-decoration: none;">+1 (234) 567-890</a>
          </div>
          <div class="mb-3">
            <i class="bi bi-geo-alt-fill me-2" style="color: #7ba4d0;"></i>
            <strong>Address:</strong> <br>123 Esports Lane, Game City, GC 12345
          </div>
          <div class="mb-3">
            <i class="bi bi-clock-fill me-2" style="color: #7ba4d0;"></i>
            <strong>Support Hours:</strong> <br>Mon-Fri: 9 AM - 6 PM EST
          </div>
        </div>
        <h4 class="mt-4 mb-3 fw-bold" style="color: #2e5e99;">Follow Us</h4>
        <div class="social-links">
          <a href="#" class="me-3" style="color: #7ba4d0; text-decoration: none;"><i class="bi bi-twitter fs-4"></i></a>
          <a href="#" class="me-3" style="color: #7ba4d0; text-decoration: none;"><i class="bi bi-discord fs-4"></i></a>
          <a href="#" class="me-3" style="color: #7ba4d0; text-decoration: none;"><i class="bi bi-youtube fs-4"></i></a>
          <a href="#" style="color: #7ba4d0; text-decoration: none;"><i class="bi bi-twitch fs-4"></i></a>
        </div>
      </div>
    </div>
  </div>
</section>

    <%- include("./includes/footer.ejs") %>
    <script src="/js/script.js"></script>
    <script src="/js/contact.js"></script>
</body>
</html>


